{%- doc -%}
  Newsletter form with configurable flow: email-then-mobile, mobile-then-email,
  email-only, or mobile-only. Submits as a single Shopify customer form.

  @param {object} section - Parent section (used for flow + step copy settings)
  @param {string} context - Form location identifier ('popup-mobile')
{%- enddoc -%}

{%- liquid
  assign section_id = section.id
  assign form_id = 'newsletter-mobile-' | append: section_id
  assign flow = section.settings.flow | default: 'email_then_mobile'
  assign allow_skip = section.settings.allow_skip

  assign show_email = true
  assign show_mobile = true
  assign first_step = 'email'

  case flow
    when 'email_then_mobile'
      assign first_step = 'email'
    when 'mobile_then_email'
      assign first_step = 'mobile'
    when 'email_only'
      assign show_mobile = false
      assign first_step = 'email'
    when 'mobile_only'
      assign show_email = false
      assign first_step = 'mobile'
  endcase

  assign step_count = 0
  if show_email
    assign step_count = step_count | plus: 1
  endif
  if show_mobile
    assign step_count = step_count | plus: 1
  endif

  assign default_tags = 'newsletter'
  if show_mobile
    assign default_tags = 'newsletter, sms-marketing-consent'
  endif
-%}

<div class="newsletter-form-mobile-wrap"
  data-newsletter-form
  data-flow="{{ flow }}"
  data-first-step="{{ first_step }}"
  data-step-count="{{ step_count }}"
  data-allow-skip="{% if allow_skip %}true{% else %}false{% endif %}"
>
  {%- form 'customer', id: form_id, class: 'newsletter-form newsletter-form--mobile grid gap-5' -%}
    <input type="hidden" name="contact[tags]" value="{{ default_tags }}" data-newsletter-tags />
    <input type="hidden" name="contact[context]" value="{{ context }}" />
    <input type="hidden" name="contact[accepts_marketing]" value="1" />
    <input type="hidden" name="contact[note]" id="NewsletterMobileNote--{{ section_id }}" value="" data-newsletter-note />

    {%- comment -%} Render steps in the configured order {%- endcomment -%}
    {%- assign order_index = 0 -%}

    {%- for slot in (1..2) -%}
      {%- liquid
        assign render_step = ''
        if forloop.first
          assign render_step = first_step
        else
          if first_step == 'email'
            assign render_step = 'mobile'
          else
            assign render_step = 'email'
          endif
        endif

        assign should_render = false
        if render_step == 'email' and show_email
          assign should_render = true
        endif
        if render_step == 'mobile' and show_mobile
          assign should_render = true
        endif
      -%}

      {%- if should_render -%}
        {%- assign order_index = order_index | plus: 1 -%}
        {%- assign is_last = false -%}
        {%- if order_index == step_count -%}{%- assign is_last = true -%}{%- endif -%}
        {%- assign is_first = false -%}
        {%- if order_index == 1 -%}{%- assign is_first = true -%}{%- endif -%}

        {%- if render_step == 'email' -%}
          <div class="newsletter-step newsletter-step--email{% if is_first %} is-active{% endif %}" data-step="{{ order_index }}" data-step-name="email">
            <div class="field relative">
              <input
                id="NewsletterMobileEmail--{{ section_id }}"
                class="input is-floating input--fill"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="{{ 'general.newsletter.label' | t | escape }}"
                required
                {%- if form.errors %} autofocus{% endif -%}
                data-newsletter-email
              />
              <label class="label is-floating" for="NewsletterMobileEmail--{{ section_id }}">{{ 'general.newsletter.label' | t }}</label>
              <div class="self-submit-button absolute">
                {%- if is_last -%}
                  <button type="submit" class="button button--primary self-button flex justify-center items-center" is="magnet-button" data-magnet="20" data-newsletter-submit aria-label="{{ 'general.newsletter.submit' | t | escape }}">
                    <span class="btn-text">
                      <svg class="icon icon-arrow-right icon-xs transform" viewBox="0 0 16 16" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2 8.00012H14M14 8.00012L9.33333 3.3335M14 8.00012L9.33333 12.6668"></path>
                      </svg>
                    </span>
                  </button>
                {%- else -%}
                  <button type="button" class="button button--primary self-button flex justify-center items-center" is="magnet-button" data-magnet="20" data-newsletter-next aria-label="{{ 'general.newsletter.next' | t | escape }}">
                    <span class="btn-text">
                      <svg class="icon icon-arrow-right icon-xs transform" viewBox="0 0 16 16" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2 8.00012H14M14 8.00012L9.33333 3.3335M14 8.00012L9.33333 12.6668"></path>
                      </svg>
                    </span>
                  </button>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- elsif render_step == 'mobile' -%}
          <div class="newsletter-step newsletter-step--mobile{% if is_first %} is-active{% endif %}" data-step="{{ order_index }}" data-step-name="mobile">
            {%- unless is_first -%}
              {%- if section.settings.step_heading != blank -%}
                <h3 class="heading leading-none text-base-xl mb-3">{{ section.settings.step_heading }}</h3>
              {%- endif -%}
              {%- if section.settings.step_text != blank -%}
                <div class="rte text-base leading-normal mb-5">{{ section.settings.step_text }}</div>
              {%- endif -%}
            {%- endunless -%}

            <div class="field relative">
              <input
                id="NewsletterMobilePhone--{{ section_id }}"
                class="input is-floating input--fill"
                type="tel"
                name="contact[phone]"
                autocomplete="tel"
                inputmode="tel"
                pattern="^\+?[0-9\s\-()]{7,}$"
                placeholder="{{ 'general.newsletter.phone_label' | t | escape }}"
                data-newsletter-phone
              />
              <label class="label is-floating" for="NewsletterMobilePhone--{{ section_id }}">{{ 'general.newsletter.phone_label' | t }}</label>
            </div>

            <label class="newsletter-consent flex gap-3 items-start text-sm leading-snug cursor-pointer mt-3" for="NewsletterMobileConsent--{{ section_id }}">
              <input
                id="NewsletterMobileConsent--{{ section_id }}"
                type="checkbox"
                class="mt-1"
                required
                data-newsletter-consent
              />
              <span>{{ 'general.newsletter.sms_consent' | t }}</span>
            </label>

            <div class="newsletter-step__actions flex gap-3 items-center mt-4">
              {%- if is_last -%}
                <button type="submit" class="button button--primary flex justify-center items-center" data-newsletter-submit>
                  <span class="btn-text">{{ 'general.newsletter.submit' | t }}</span>
                </button>
              {%- else -%}
                <button type="button" class="button button--primary flex justify-center items-center" data-newsletter-next>
                  <span class="btn-text">{{ 'general.newsletter.next' | t }}</span>
                </button>
              {%- endif -%}

              {%- if allow_skip and step_count > 1 and is_last == false -%}
                <button type="button" class="link inline-block" data-newsletter-skip>
                  {{- 'general.newsletter.skip' | t -}}
                </button>
              {%- endif -%}

              {%- if allow_skip and step_count > 1 and is_last -%}
                <button type="button" class="link inline-block" data-newsletter-skip-final>
                  {{- 'general.newsletter.skip' | t -}}
                </button>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- liquid
      if form.errors and form.context == context
        assign form_errors = form.errors | default_errors
        render 'alert', status: 'error', content: form_errors
      endif

      if form.posted_successfully?
        assign success_message = 'general.newsletter.success' | t
        render 'alert', status: 'success', content: success_message
      endif
    -%}
  {%- endform -%}
</div>
