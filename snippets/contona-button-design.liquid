{%- comment -%}
  Contona Button Design
  Emits the Contona Room Visualiser product data feed + button styling/position CSS from
  the block settings. The button (#__contona-tryon-btn) is injected by Contona into
  [data-contona-anchor] overlays inside the first product image (snippets/
  product-media-gallery.liquid + product-media.liquid). Contona runs in inline mode, so
  the anchor's position controls the button's position. Position = 9-point preset per
  device + numeric X/Y nudge.

  Accepts: block (the contona_button_design block), product
{%- endcomment -%}
{%- liquid
  assign s = block.settings
-%}
<style>
  .contona-visualiser-anchor {
    position: absolute !important;
    z-index: 2;
    pointer-events: none;
    {%- render 'contona-anchor-rules', position: s.m_position, offx: s.m_offset_x, offy: s.m_offset_y -%}
  }
  @media screen and (min-width: 768px) {
    .contona-visualiser-anchor { {%- render 'contona-anchor-rules', position: s.t_position, offx: s.t_offset_x, offy: s.t_offset_y -%} }
  }
  @media screen and (min-width: 1024px) {
    .contona-visualiser-anchor { {%- render 'contona-anchor-rules', position: s.d_position, offx: s.d_offset_x, offy: s.d_offset_y -%} }
  }
  #__contona-tryon-btn {
    pointer-events: auto !important;
    margin: 0 !important;
    background-color: {{ s.bg_color }} !important;
    color: {{ s.text_color }} !important;
    border: none !important;
    box-shadow: none !important;
    font-weight: 500 !important;
    line-height: 1 !important;
    width: max-content !important;
    cursor: pointer !important;
    border-radius: {{ s.radius }}px !important;
    font-size: {{ s.font_size }}px !important;
    padding: {{ s.padding_y }}px {{ s.padding_x }}px !important;
  }
  {%- comment -%} At xl the big image is the sticky preview; hide the duplicate injected into the slider's featured tile. {%- endcomment -%}
  @media screen and (min-width: 1280px) {
    .product__media-list #__contona-tryon-btn { display: none !important; }
  }
</style>
<script type="application/json" data-contona-product>
  {
    "id": {{ product.id | json }},
    "title": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "type": {{ product.type | json }},
    "vendor": {{ product.vendor | json }},
    "tags": {{ product.tags | json }},
    "collections": [{%- for c in product.collections -%}"{{ c.handle }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
    "price": "{{ product.price | money_without_currency }}",
    "url": "{{ product.url }}",
    "images": [{%- for img in product.images limit:5 -%}{"url":{{ img | image_url: width: 1024 | json }},"label":{{ img.alt | default: 'image' | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
    "variants": [{%- for v in product.variants -%}{"id":{{ v.id | json }},"label":{{ v.title | json }},"image":{{ v.featured_image | default: product.featured_image | image_url: width: 1024 | json }},"price":{{ v.price | money | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]
  }
</script>
