{%- doc -%}
  Renders product pricing with sale detection, unit prices, and dynamic price ranges.

  Displays comprehensive pricing information including regular prices, sale prices, price ranges for products with variants, and unit pricing. Automatically detects sales, formats currencies, and handles various pricing scenarios with proper accessibility support.

  When "Hide Out-of-Stock Variants" is active for the product (see snippets/oos-visibility.liquid),
  the product-range price ("From £X" / single price / compare / savings) is computed from AVAILABLE
  variants only, so a sold-out cheaper variant never sets the advertised price. The per-variant path
  (use_variant) is unchanged — it shows the selected variant, which the picker keeps available.

  @param {object} [product] - Shopify product object for pricing
  @param {object} [variant] - Specific variant for single price display
  @param {boolean} [use_variant] - Show variant price vs product range
  @param {boolean} [placeholder] - Display placeholder $19.99 price
  @param {boolean} [hide_unit_price] - Hide unit price information
  @param {boolean} [hide_sale_price] - Hide compare at (sale) price
  @param {boolean} [skip_to_price] - Skip quantity break considerations
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'product-price',
     product: product,
     variant: product.selected_variant,
     use_variant: true
  %}
{%- enddoc -%}

{%- liquid
  capture hide_oos_raw
    render 'oos-visibility', product: product
  endcapture
  assign hide_oos = hide_oos_raw | strip

  if use_variant
    assign target = variant | default: product.selected_or_first_available_variant
  elsif placeholder
    assign target = null
  else
    assign target = product
  endif

  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign price_varies = false
  if target == product
    assign price_varies = product.price_varies
  endif

  comment
    Product-range case (collection cards etc.): recompute min price / varies / compare from
    available variants only when OOS variants are being hidden for this product.
  endcomment
  if hide_oos == 'true' and target == product
    assign avail_min = null
    assign avail_max = null
    assign rep_variant = null
    for v in product.variants
      unless v.available
        continue
      endunless
      if avail_min == null or v.price < avail_min
        assign avail_min = v.price
        assign rep_variant = v
      endif
      if avail_max == null or v.price > avail_max
        assign avail_max = v.price
      endif
    endfor
    if avail_min != null
      assign price = avail_min
      assign compare_at_price = rep_variant.compare_at_price
      assign price_varies = false
      if avail_max != avail_min
        assign price_varies = true
      endif
    endif
  endif

  assign on_sale = false
  unless hide_sale_price
    if compare_at_price > price
      assign on_sale = true
    endif
  endunless
-%}

<div class="price
  {%- if on_sale %} price--on-sale{% endif -%}
  {%- if class != blank %} {{ class }}{% endif -%}"
>
  {%- if on_sale -%}
    <span class="sr-only">{{ 'products.price.sale_price' | t }}</span>
  {%- endif -%}

  <span class="price__regular whitespace-nowrap">
    {%- liquid
      if product.quantity_price_breaks_configured? != true or skip_to_price
        if target == product and price_varies
          if settings.currency_code_enabled
            assign price_from = price | money_with_currency
          else
            assign price_from = price | money
          endif
          echo 'products.price.from_price_html' | t: price: price_from
        else
          if settings.currency_code_enabled
            echo price | money_with_currency
          else
            echo price | money
          endif
        endif
      else
        if settings.currency_code_enabled
          assign price_from = price | money_with_currency
        else
          assign price_from = price | money
        endif
        echo 'products.price.from_price_html' | t: price: price_from
      endif
    -%}
  </span>

  {%- if on_sale -%}
    <span class="sr-only">{{ 'products.price.regular_price' | t }}</span>
    {%- capture savings -%}
      {{- compare_at_price | minus: price | money_without_trailing_zeros -}}
    {%- endcapture -%}
    <span class="price__compare inline-flex items-center gap-2 md:gap-1d5">
      <span class="price__sale inline-flex items-center h-auto relative">
        {%- liquid
          if settings.currency_code_enabled
            echo compare_at_price | money_with_currency
          else
            echo compare_at_price | money
          endif
        -%}
      </span>
      <span class="price__save inline-flex items-center">
        {{- 'products.price.save_amount_html' | t: savings: savings -}}
      </span>
    </span>
  {%- endif -%}

  {%- unless hide_unit_price -%}
    {%- assign product_variant = product.selected_or_first_available_variant -%}
    {%- if product_variant.unit_price_measurement -%}
      <span class="sr-only">{{ 'products.price.unit_price' | t }}</span>
      <span class="unit-price flex items-center">
        {%- liquid
          capture unit_price_base_unit
            if product_variant.unit_price_measurement
              if product_variant.unit_price_measurement.reference_value != 1
                echo product_variant.unit_price_measurement.reference_value
              endif
              echo product_variant.unit_price_measurement.reference_unit
            endif
          endcapture
        -%}
        ({{ product_variant.unit_price | money }}
        <span aria-hidden="true">/</span>
        <span class="sr-only">&nbsp;{{ 'general.accessibility.unit_price_separator' | t }}&nbsp;</span>
        {{ unit_price_base_unit }})
        </span>
    {%- endif -%}
  {%- endunless -%}
</div>
