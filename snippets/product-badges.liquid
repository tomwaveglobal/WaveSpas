{%- liquid
  assign current_country = localization.country.iso_code | upcase

  if badge_context == 'nav'
    assign badge_mode = settings.advanced_badge_mode_nav
  else
    case template.name
      when 'product'
        assign badge_mode = settings.advanced_badge_mode_product
      when 'collection'
        assign badge_mode = settings.advanced_badge_mode_collection
      when 'index'
        assign badge_mode = settings.advanced_badge_mode_home
      when 'search'
        assign badge_mode = settings.advanced_badge_mode_search
      else
        assign badge_mode = 'hidden'
    endcase
  endif

  assign badge_mode = badge_mode | default: 'hidden'
-%}
{%- if badge_mode != 'hidden' -%}
<div class="badges{% if class != blank %} {{ class }}{% endif %} pointer-events-none">
  {%- liquid
    assign badge_bg = product.metafields.theme.label_color.value | default: settings.product_badge_bg_color
    assign badge_fg = settings.product_badge_text_color | default: '#ffffff'
  -%}
  {%- capture styles -%}
    {%- if badge_bg != blank -%}--badge-background: {{ badge_bg }};{%- endif -%}
    {%- if badge_fg != blank -%}--badge-foreground: {{ badge_fg }};{%- endif -%}
  {%- endcapture -%}

  {%- comment -%} Delimited, downcased index of every variant barcode + SKU for fast matching. {%- endcomment -%}
  {%- assign variant_code_index = '' -%}
  {%- for variant in product.variants -%}
    {%- assign variant_code_index = variant_code_index | append: '|' | append: variant.barcode | append: '|' | append: variant.sku -%}
  {%- endfor -%}
  {%- assign variant_code_index = variant_code_index | append: '|' | downcase -%}

  {%- comment -%} Track which modules have rendered so a product never shows the same module twice. {%- endcomment -%}
  {%- assign rendered_modules = '' -%}

  {%- comment -%}
    1. Metafield-driven badges (product.metafields.theme.label). When a matched module's Variant Focus
    also matches this product, the module swaps to its Override badge (image/text) instead of the base.
  {%- endcomment -%}
  {%- assign label_value = product.metafields.theme.label.value -%}
  {%- if label_value != blank -%}
    {%- assign label_entries = label_value | split: ';' -%}
    {%- for entry in label_entries -%}
      {%- assign entry_trimmed = entry | strip -%}
      {%- if entry_trimmed == blank -%}
        {%- continue -%}
      {%- endif -%}

      {%- assign show_label = false -%}
      {%- assign label_text = '' -%}

      {%- if entry_trimmed contains ':' -%}
        {%- assign colon_parts = entry_trimmed | split: ':' -%}
        {%- assign countries_raw = colon_parts.first | strip | upcase -%}
        {%- assign text_parts = colon_parts | slice: 1, 999 -%}
        {%- assign label_text = text_parts | join: ':' | strip -%}
        {%- assign country_list = countries_raw | split: ',' -%}
        {%- for cc in country_list -%}
          {%- assign cc_trimmed = cc | strip -%}
          {%- if cc_trimmed == current_country -%}
            {%- assign show_label = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign label_text = entry_trimmed -%}
        {%- assign show_label = true -%}
      {%- endif -%}

      {%- if show_label and label_text != blank -%}
        {%- comment -%} Defaults for a custom (non-module) label entry: a plain text pill. {%- endcomment -%}
        {%- assign matched_module = 0 -%}
        {%- assign badge_text = label_text -%}
        {%- assign badge_image = blank -%}
        {%- assign badge_show_text = true -%}

        {%- if settings.advanced_badge_map_1_text != blank and settings.advanced_badge_map_1_text == label_text -%}
          {%- assign matched_module = 1 -%}
        {%- elsif settings.advanced_badge_map_2_text != blank and settings.advanced_badge_map_2_text == label_text -%}
          {%- assign matched_module = 2 -%}
        {%- elsif settings.advanced_badge_map_3_text != blank and settings.advanced_badge_map_3_text == label_text -%}
          {%- assign matched_module = 3 -%}
        {%- elsif settings.advanced_badge_map_4_text != blank and settings.advanced_badge_map_4_text == label_text -%}
          {%- assign matched_module = 4 -%}
        {%- elsif settings.advanced_badge_map_5_text != blank and settings.advanced_badge_map_5_text == label_text -%}
          {%- assign matched_module = 5 -%}
        {%- elsif settings.advanced_badge_map_6_text != blank and settings.advanced_badge_map_6_text == label_text -%}
          {%- assign matched_module = 6 -%}
        {%- elsif settings.advanced_badge_map_7_text != blank and settings.advanced_badge_map_7_text == label_text -%}
          {%- assign matched_module = 7 -%}
        {%- elsif settings.advanced_badge_map_8_text != blank and settings.advanced_badge_map_8_text == label_text -%}
          {%- assign matched_module = 8 -%}
        {%- elsif settings.advanced_badge_map_9_text != blank and settings.advanced_badge_map_9_text == label_text -%}
          {%- assign matched_module = 9 -%}
        {%- elsif settings.advanced_badge_map_10_text != blank and settings.advanced_badge_map_10_text == label_text -%}
          {%- assign matched_module = 10 -%}
        {%- endif -%}

        {%- if matched_module > 0 -%}
          {%- assign base_image_key = 'advanced_badge_map_' | append: matched_module | append: '_image' -%}
          {%- assign base_show_key = 'advanced_badge_map_' | append: matched_module | append: '_show_text' -%}
          {%- assign focus_key = 'advanced_badge_map_' | append: matched_module | append: '_variant_focus' -%}
          {%- assign ov_text_key = 'advanced_badge_map_' | append: matched_module | append: '_override_text' -%}
          {%- assign ov_image_key = 'advanced_badge_map_' | append: matched_module | append: '_override_image' -%}
          {%- assign ov_show_key = 'advanced_badge_map_' | append: matched_module | append: '_override_show_text' -%}

          {%- assign focus_value = settings[focus_key] -%}
          {%- assign ov_text = settings[ov_text_key] -%}
          {%- assign ov_image = settings[ov_image_key] -%}

          {%- assign variant_match = false -%}
          {%- if focus_value != blank -%}
            {%- capture variant_match_raw -%}{%- render 'badge-variant-match', codes: focus_value, index: variant_code_index -%}{%- endcapture -%}
            {%- if variant_match_raw contains 'true' -%}
              {%- assign variant_match = true -%}
            {%- endif -%}
          {%- endif -%}

          {%- assign has_override = false -%}
          {%- if ov_text != blank or ov_image != blank -%}
            {%- assign has_override = true -%}
          {%- endif -%}

          {%- if variant_match and has_override -%}
            {%- assign badge_text = ov_text | default: label_text -%}
            {%- assign badge_image = ov_image -%}
            {%- assign badge_show_text = settings[ov_show_key] -%}
          {%- else -%}
            {%- assign badge_text = label_text -%}
            {%- assign badge_image = settings[base_image_key] -%}
            {%- assign badge_show_text = settings[base_show_key] -%}
          {%- endif -%}

          {%- assign rendered_modules = rendered_modules | append: '|' | append: matched_module | append: '|' -%}
        {%- endif -%}

        {%- render 'product-badge-item', badge_mode: badge_mode, label_text: badge_text, badge_image: badge_image, badge_show_text: badge_show_text, styles: styles -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%}
    2. Variant-focus badges for modules not already shown above. A matching variant shows the module's
    Override badge if one is set, otherwise its base badge — no metafield label required.
  {%- endcomment -%}
  {%- for i in (1..10) -%}
    {%- assign module_needle = '|' | append: i | append: '|' -%}
    {%- if rendered_modules contains module_needle -%}
      {%- continue -%}
    {%- endif -%}

    {%- assign focus_key = 'advanced_badge_map_' | append: i | append: '_variant_focus' -%}
    {%- assign focus_value = settings[focus_key] -%}
    {%- if focus_value == blank -%}
      {%- continue -%}
    {%- endif -%}

    {%- capture variant_match_raw -%}{%- render 'badge-variant-match', codes: focus_value, index: variant_code_index -%}{%- endcapture -%}
    {%- unless variant_match_raw contains 'true' -%}
      {%- continue -%}
    {%- endunless -%}

    {%- assign base_text_key = 'advanced_badge_map_' | append: i | append: '_text' -%}
    {%- assign base_image_key = 'advanced_badge_map_' | append: i | append: '_image' -%}
    {%- assign base_show_key = 'advanced_badge_map_' | append: i | append: '_show_text' -%}
    {%- assign ov_text_key = 'advanced_badge_map_' | append: i | append: '_override_text' -%}
    {%- assign ov_image_key = 'advanced_badge_map_' | append: i | append: '_override_image' -%}
    {%- assign ov_show_key = 'advanced_badge_map_' | append: i | append: '_override_show_text' -%}
    {%- assign ov_text = settings[ov_text_key] -%}
    {%- assign ov_image = settings[ov_image_key] -%}
    {%- assign ov_show = settings[ov_show_key] -%}

    {%- assign has_override = false -%}
    {%- if ov_text != blank or ov_image != blank -%}
      {%- assign has_override = true -%}
    {%- endif -%}

    {%- if has_override -%}
      {%- assign focus_text = ov_text | default: settings[base_text_key] -%}
      {%- assign focus_image = ov_image -%}
      {%- assign focus_show_text = ov_show -%}
    {%- else -%}
      {%- assign focus_text = settings[base_text_key] -%}
      {%- assign focus_image = settings[base_image_key] -%}
      {%- assign focus_show_text = settings[base_show_key] -%}
    {%- endif -%}

    {%- render 'product-badge-item', badge_mode: badge_mode, label_text: focus_text, badge_image: focus_image, badge_show_text: focus_show_text, styles: styles -%}
    {%- assign rendered_modules = rendered_modules | append: '|' | append: i | append: '|' -%}
  {%- endfor -%}
</div>
{%- endif -%}
