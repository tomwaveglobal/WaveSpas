{%- doc -%}
  Stepped/guided variant picker (Colour → Size → Edition → Add-Ons).

  Step display order is derived from option name ("colour"/"size"/
  "edition|bundle|version") regardless of Shopify's option positions.
  Numbered badges (1/2/3/4) follow display order. All earlier steps stay
  interactive — selecting a new colour at any point re-resolves the
  variant and updates the rest of the picker live.

  Feature summary
  ---------------
  • Variant-level Most Popular pill — gated on the resolved variant's
    inventory > most_popular_min_stock.
  • Sold Out treatment on the Size step only.
  • Per-tile pre-order chip from variant.metafields.custom.
    pre_order_date_{uk|eu|usa}, market-aware.
  • Auto-shown Energy-Saving Bundle blurb when the value name contains
    "energy"/"saving"/"eco". Copy editable in admin.
  • Step 4 (Add-Ons) hidden until all earlier steps are picked, then
    fades in. Reads product.metafields.custom.popular_upgrades.
  • Add-on variant resolution: explicit SKU map → SKU-prefix match →
    keyword/title match fallback. Out-of-stock matches hide the row.
  • Subscriptions: per-row delivery-frequency selector when the add-on
    has selling_plan_groups. Subscription pre-selected by default.
  • Cart submit: capture-phase click intercept on the host form, routes
    through /cart/add.js sequentially (reliable with selling plans).

  @param {object} product
  @param {object} block - The main-product variant_picker_advanced block
  @param {string} product_form_id - host form id (so we can update its `id` input)
  @param {string} product_id
  @param {string} section_id
{%- enddoc -%}

{%- liquid
  # ─── Market-aware pre-order metafield key ───────────────────────────
  case localization.market.metafields.country.code
    when 'UK'
      assign pre_order_key = 'pre_order_date_uk'
    when 'EU'
      assign pre_order_key = 'pre_order_date_eu'
    when 'US'
      assign pre_order_key = 'pre_order_date_usa'
    else
      assign pre_order_key = 'pre_order_date_uk'
  endcase

  # ─── Derived values ────────────────────────────────────────────────
  assign vpa_id = 'vpa-' | append: section_id | append: '-' | append: product_id
  assign popular_upgrades = product.metafields.custom.popular_upgrades.value
  assign addons_enabled = block.settings.addons_enabled
  if popular_upgrades == blank
    assign addons_enabled = false
  endif
  assign size_chart = block.settings.size_chart
  assign most_popular_min_stock = block.settings.most_popular_min_stock | default: 0
-%}

{%- unless product.has_only_default_variant -%}

<style>
  /* ═══ Layout shell ════════════════════════════════════════════════ */
  .vpa {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    --vpa-border: rgb(var(--color-foreground) / 0.10);
    --vpa-border-strong: rgb(var(--color-foreground) / 0.85);
    --vpa-surface-muted: rgb(var(--color-foreground) / 0.03);
    --vpa-surface-card: rgb(var(--color-foreground) / 0.02);
    --vpa-text-muted: rgb(var(--color-foreground) / 0.6);
    --vpa-accent: rgb(var(--color-highlight));
    --vpa-accent-soft: rgb(var(--color-highlight) / 0.10);
    --vpa-info-bg: rgb(var(--color-foreground) / 0.04);
    --vpa-sale: rgb(var(--color-sale-tag));
    --vpa-sale-text: rgb(var(--color-sale-tag-text));
  }

  /* ═══ Step container ══════════════════════════════════════════════ */
  .vpa__step {
    border: 1px solid var(--vpa-border);
    border-radius: var(--rounded-card, 14px);
    background: var(--vpa-surface-card);
    padding: var(--sp-4) var(--sp-5);
    transition: opacity 0.2s, border-color 0.2s, background 0.2s;
  }
  @media (min-width: 768px) { .vpa__step { padding: var(--sp-5) var(--sp-6); } }
  .vpa__step--complete { border-color: rgb(var(--color-foreground) / 0.18); background: rgb(var(--color-background)); }
  .vpa__step--locked { opacity: 0.45; pointer-events: none; }
  .vpa__step--locked .vpa__num { border-color: var(--vpa-text-muted); color: var(--vpa-text-muted); background: transparent; }
  .vpa__head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-block-end: var(--sp-4);
    padding: 0;
    width: 100%;
    flex-wrap: wrap;
  }
  .vpa__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid rgb(var(--color-foreground));
    color: rgb(var(--color-foreground));
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s;
  }
  .vpa__step--complete .vpa__num { background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); }
  .vpa__title { font-size: var(--text-base); font-weight: var(--font-bold); }
  @media (min-width: 768px) { .vpa__title { font-size: var(--text-lg); } }
  .vpa__status { margin-inline-start: auto; font-size: var(--text-xs); color: var(--vpa-text-muted); font-weight: var(--font-medium); }
  .vpa__status:not(:empty)::before { content: '✓ '; color: var(--vpa-accent); font-weight: var(--font-bold); }
  .vpa__size-chart-link {
    font-size: var(--text-sm);
    color: var(--vpa-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    background: none;
    border: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
  }
  .vpa__size-chart-link:hover { color: rgb(var(--color-foreground)); }

  /* ═══ Hidden inputs — sr-only clip technique ══════════════════════ */
  .vpa__swatch input,
  .vpa__tile input,
  .vpa__text-btn input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ═══ Colour swatches (image-based) ═══════════════════════════════ */
  .vpa__choices--swatch { display: flex; flex-wrap: wrap; gap: var(--sp-3); }
  .vpa__swatch {
    position: relative;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-1d5);
    width: 64px;
  }
  .vpa__swatch-fill {
    display: block;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    box-shadow: inset 0 0 0 2px rgb(var(--color-background)), 0 0 0 1px var(--vpa-border);
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .vpa__swatch:hover .vpa__swatch-fill { box-shadow: inset 0 0 0 2px rgb(var(--color-background)), 0 0 0 2px var(--vpa-text-muted); }
  .vpa__swatch input:checked + .vpa__swatch-fill {
    box-shadow: inset 0 0 0 3px rgb(var(--color-background)), 0 0 0 2px var(--vpa-border-strong);
    transform: scale(1.05);
  }
  .vpa__swatch input:focus-visible + .vpa__swatch-fill { outline: 2px solid var(--vpa-accent); outline-offset: 3px; }
  .vpa__swatch-label { font-size: var(--text-xs); text-align: center; line-height: 1.2; color: var(--vpa-text-muted); word-wrap: break-word; }
  .vpa__swatch-soldout {
    display: block;
    font-size: 9px;
    line-height: 1;
    color: rgb(var(--color-foreground) / 0.5);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-block-start: 4px;
  }

  /* ═══ Colour text buttons (when swatches disabled) ════════════════ */
  .vpa__choices--text { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .vpa__text-btn {
    position: relative;
    cursor: pointer;
    padding: var(--sp-2) var(--sp-3d5);
    border: 1px solid var(--vpa-border);
    border-radius: var(--rounded-button, 6px);
    background: rgb(var(--color-background));
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    transition: border-color 0.15s, background 0.15s;
  }
  .vpa__text-btn:hover { border-color: var(--vpa-text-muted); }
  .vpa__text-btn:has(input:checked) { border-color: var(--vpa-border-strong); background: var(--vpa-surface-muted); }

  /* ═══ Tile cards (size / edition / etc.) ══════════════════════════ */
  .vpa__choices--tile { display: grid; grid-template-columns: 1fr; gap: var(--sp-2d5); }
  @media (min-width: 480px) {
    .vpa__choices--tile { grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr)); }
  }
  .vpa__tile {
    position: relative;
    cursor: pointer;
    border: 1.5px solid var(--vpa-border);
    border-radius: var(--rounded-card, 12px);
    background: rgb(var(--color-background));
    padding: var(--sp-3d5);
    padding-block-start: var(--sp-6);
    display: block;
    transition: border-color 0.15s, background 0.15s;
  }
  .vpa__tile:hover { border-color: var(--vpa-text-muted); }
  .vpa__tile:has(input:checked) { border-color: var(--vpa-border-strong); background: var(--vpa-surface-muted); }
  .vpa__tile:has(input:focus-visible) { outline: 2px solid var(--vpa-accent); outline-offset: 2px; }
  .vpa__tile--sold-out { opacity: 0.7; }
  .vpa__tile--sold-out .vpa__tile-name { text-decoration: line-through; text-decoration-color: rgb(var(--color-foreground) / 0.4); }
  .vpa__tile-body { display: grid; grid-template-columns: 48px minmax(0, 1fr); gap: var(--sp-2d5); align-items: start; }
  .vpa__tile-media { width: 48px; height: 48px; border-radius: var(--rounded-block, 10px); background: var(--vpa-surface-muted); overflow: hidden; flex-shrink: 0; }
  .vpa__tile-media img { width: 100%; height: 100%; object-fit: cover; }
  .vpa__tile-text { min-width: 0; }
  .vpa__tile-name { font-weight: var(--font-bold); font-size: var(--text-sm); line-height: 1.2; margin-block-end: 2px; }
  @media (min-width: 768px) { .vpa__tile-name { font-size: var(--text-base); } }
  .vpa__tile-price { font-size: var(--text-sm); display: flex; flex-wrap: wrap; align-items: baseline; gap: var(--sp-1d5); line-height: 1.2; font-weight: var(--font-bold); }
  .vpa__tile-price del { color: var(--vpa-text-muted); font-size: 0.8em; font-weight: var(--font-regular); opacity: 0.7; }

  /* ═══ Tile corner pills (Most Popular / Sold Out / % OFF) ═════════ */
  .vpa__tag, .vpa__discount {
    position: absolute;
    top: var(--sp-2);
    font-size: 9.5px;
    font-weight: var(--font-bold);
    padding: 2.5px 6px;
    border-radius: var(--rounded-full, 999px);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    z-index: 1;
    line-height: 1;
  }
  .vpa__tag { left: var(--sp-2d5); background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); }
  .vpa__tag--sold-out { background: rgb(var(--color-foreground) / 0.45); }
  .vpa__discount { right: var(--sp-2d5); background: var(--vpa-sale); color: var(--vpa-sale-text); }

  /* ═══ Tile soft pills: pre-order chip, info banner ════════════════ */
  /* The pre-order chip can carry a long market-specific string; clamp it
     to 2 lines so it never blows the tile height on narrow columns. */
  .vpa__chip, .vpa__tile-info {
    display: block;
    margin-block-start: var(--sp-2);
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 10.5px;
    line-height: 1.3;
    max-width: 100%;
    word-wrap: break-word;
  }
  .vpa__chip[hidden], .vpa__tile-info[hidden] { display: none; }
  .vpa__chip {
    background: var(--vpa-accent-soft);
    color: rgb(var(--color-foreground));
    font-weight: var(--font-medium);
    display: inline-flex;
    align-items: flex-start;
    gap: 5px;
  }
  .vpa__chip .icon { width: 11px; height: 11px; flex-shrink: 0; margin-block-start: 1px; }
  .vpa__chip-text {
    min-width: 0;
    word-wrap: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .vpa__tile-info { background: var(--vpa-info-bg); color: rgb(var(--color-foreground)); }
  .vpa__tile-info strong { font-weight: var(--font-bold); }

  /* ═══ Dynamic-options "unavailable" treatment ═════════════════════ */
  .vpa__choice--unavailable { opacity: 0.35; pointer-events: none; position: relative; }
  .vpa__choice--unavailable::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent calc(50% - 1px), rgb(var(--color-foreground) / 0.15) 50%, transparent calc(50% + 1px));
    border-radius: inherit;
    pointer-events: none;
  }

  /* ═══ Step 4 — Add-Ons (reveals when core steps complete) ═════════ */
  .vpa__step--addons {
    opacity: 0;
    transform: translateY(20px);
    max-height: 0;
    padding-block: 0;
    margin: 0;
    border-width: 0;
    overflow: hidden;
    transition: opacity 0.4s ease, transform 0.4s ease, max-height 0.5s ease, padding 0.4s ease, border-width 0.2s ease;
    pointer-events: none;
  }
  .vpa__step--addons[data-revealed="true"] {
    opacity: 1;
    transform: translateY(0);
    max-height: 2000px;
    padding: var(--sp-4) var(--sp-5);
    border-width: 1px;
    pointer-events: auto;
  }
  @media (min-width: 768px) {
    .vpa__step--addons[data-revealed="true"] { padding: var(--sp-5) var(--sp-6); }
  }

  /* ═══ Add-on row (each Popular Add-On entry) ══════════════════════ */
  .vpa__addon-list { display: flex; flex-direction: column; gap: var(--sp-2); }
  .vpa__addon {
    display: grid;
    grid-template-columns: auto 48px 1fr auto;
    align-items: center;
    gap: var(--sp-3);
    border: 1px solid var(--vpa-border);
    border-radius: var(--rounded-block, 10px);
    padding: var(--sp-2d5) var(--sp-3d5);
    background: rgb(var(--color-background));
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .vpa__addon[hidden] { display: none; }
  .vpa__addon:hover { border-color: var(--vpa-text-muted); }
  .vpa__addon:has(input.vpa__addon-check:checked) { border-color: var(--vpa-border-strong); background: var(--vpa-surface-muted); }
  .vpa__addon-check {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid var(--vpa-border-strong);
    border-radius: 4px;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    background: rgb(var(--color-background));
  }
  .vpa__addon-check:checked { background: rgb(var(--color-foreground)); border-color: rgb(var(--color-foreground)); }
  .vpa__addon-check:checked::after {
    content: '';
    position: absolute;
    left: 4px; top: 0;
    width: 5px; height: 10px;
    border: solid rgb(var(--color-background));
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .vpa__addon-media { width: 48px; height: 48px; border-radius: 8px; background: var(--vpa-surface-muted); overflow: hidden; }
  .vpa__addon-media img { width: 100%; height: 100%; object-fit: cover; }
  .vpa__addon-name-wrap { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .vpa__addon-name { font-weight: var(--font-bold); font-size: var(--text-sm); line-height: 1.3; min-width: 0; }
  .vpa__addon-variant { font-size: 11px; color: var(--vpa-text-muted); font-weight: var(--font-medium); line-height: 1.2; }
  .vpa__addon-variant::before { content: 'Variant: '; opacity: 0.7; }
  .vpa__addon-price { font-weight: var(--font-bold); font-size: var(--text-sm); white-space: nowrap; }

  /* ═══ Add-on subscription panel ═══════════════════════════════════ */
  .vpa__addon-sub {
    grid-column: 1 / -1;
    margin-block-start: var(--sp-2d5);
    padding: var(--sp-2d5) var(--sp-3);
    background: var(--vpa-accent-soft);
    border-radius: 8px;
    display: none;
    flex-direction: column;
    gap: var(--sp-1d5);
  }
  .vpa__addon:has(input.vpa__addon-check:checked) .vpa__addon-sub { display: flex; }
  .vpa__addon-sub-head { display: flex; align-items: center; gap: var(--sp-2); }
  .vpa__addon-sub-savings {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-weight: var(--font-bold);
    font-size: 12px;
    color: rgb(var(--color-foreground));
    letter-spacing: 0.02em;
  }
  .vpa__addon-sub-savings::before { content: '⟳'; font-size: 14px; color: var(--vpa-accent); }
  .vpa__addon-sub-desc { font-size: 11px; line-height: 1.4; color: var(--vpa-text-muted); }
  .vpa__addon-sub select {
    width: 100%;
    font-size: 13px;
    padding: 8px 28px 8px 12px;
    border-radius: 6px;
    border: 1px solid var(--vpa-border);
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2'%3e%3cpath d='M6 9l6 6 6-6'/%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 8px center;
    background-size: 14px;
  }
  .vpa__addon-sub select:focus { outline: 2px solid var(--vpa-accent); outline-offset: 1px; }

  /* ═══ Narrow-screen layout adjustments for add-on rows ════════════ */
  @media (max-width: 479px) {
    .vpa__addon { grid-template-columns: auto 40px 1fr; }
    .vpa__addon-media { width: 40px; height: 40px; }
    .vpa__addon-price { grid-column: 2 / -1; padding-inline-start: calc(40px + var(--sp-3)); }
    .vpa__addon-sub { padding-inline-start: 0; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     SIZE PRESETS — same layout, scaled density. Switchable per-block via
     the Size preset setting (XS / S / M / L). Each preset is scoped to
     .vpa[data-vpa-size="…"] so they compose with the base styles above
     and never bleed across instances on the same page.
  ═══════════════════════════════════════════════════════════════════ */

  /* ─── XS — Ultra compact ───────────────────────────────────────── */
  .vpa[data-vpa-size="xs"] { gap: var(--sp-2); }
  .vpa[data-vpa-size="xs"] .vpa__step { padding: var(--sp-3) var(--sp-3d5); }
  @media (min-width: 768px) { .vpa[data-vpa-size="xs"] .vpa__step { padding: var(--sp-3d5) var(--sp-4); } }
  .vpa[data-vpa-size="xs"] .vpa__head { margin-block-end: var(--sp-3); gap: var(--sp-2); }
  .vpa[data-vpa-size="xs"] .vpa__num { width: 22px; height: 22px; font-size: 11px; border-width: 1.25px; }
  .vpa[data-vpa-size="xs"] .vpa__title { font-size: var(--text-sm); }
  @media (min-width: 768px) { .vpa[data-vpa-size="xs"] .vpa__title { font-size: var(--text-base); } }
  .vpa[data-vpa-size="xs"] .vpa__status { font-size: 10px; }
  .vpa[data-vpa-size="xs"] .vpa__choices--tile { gap: var(--sp-2); }
  .vpa[data-vpa-size="xs"] .vpa__tile { padding: var(--sp-2d5); padding-block-start: var(--sp-5); border-width: 1px; }
  .vpa[data-vpa-size="xs"] .vpa__tile-body { grid-template-columns: 36px minmax(0, 1fr); gap: var(--sp-2); }
  .vpa[data-vpa-size="xs"] .vpa__tile-media { width: 36px; height: 36px; }
  .vpa[data-vpa-size="xs"] .vpa__tile-name { font-size: var(--text-xs); }
  @media (min-width: 768px) { .vpa[data-vpa-size="xs"] .vpa__tile-name { font-size: var(--text-sm); } }
  .vpa[data-vpa-size="xs"] .vpa__tile-price { font-size: var(--text-xs); gap: var(--sp-1); }
  .vpa[data-vpa-size="xs"] .vpa__tag, .vpa[data-vpa-size="xs"] .vpa__discount { font-size: 8.5px; padding: 2px 5px; top: var(--sp-1d5); }
  .vpa[data-vpa-size="xs"] .vpa__tag { left: var(--sp-2); }
  .vpa[data-vpa-size="xs"] .vpa__discount { right: var(--sp-2); }
  .vpa[data-vpa-size="xs"] .vpa__chip, .vpa[data-vpa-size="xs"] .vpa__tile-info { font-size: 9.5px; padding: 3px 6px; margin-block-start: var(--sp-1d5); }
  .vpa[data-vpa-size="xs"] .vpa__chip .icon { width: 10px; height: 10px; }
  .vpa[data-vpa-size="xs"] .vpa__swatch { width: 50px; gap: var(--sp-1); }
  .vpa[data-vpa-size="xs"] .vpa__swatch-fill { width: 32px; height: 32px; }
  .vpa[data-vpa-size="xs"] .vpa__swatch-label { font-size: 10px; }

  /* ─── S — Compact ──────────────────────────────────────────────── */
  .vpa[data-vpa-size="s"] .vpa__step { padding: var(--sp-3d5) var(--sp-4); }
  @media (min-width: 768px) { .vpa[data-vpa-size="s"] .vpa__step { padding: var(--sp-4) var(--sp-5); } }
  .vpa[data-vpa-size="s"] .vpa__head { margin-block-end: var(--sp-3); }
  .vpa[data-vpa-size="s"] .vpa__num { width: 24px; height: 24px; font-size: 12px; }
  .vpa[data-vpa-size="s"] .vpa__choices--tile { gap: var(--sp-2); }
  .vpa[data-vpa-size="s"] .vpa__tile { padding: var(--sp-3); padding-block-start: var(--sp-5d5); }
  .vpa[data-vpa-size="s"] .vpa__tile-body { grid-template-columns: 42px minmax(0, 1fr); gap: var(--sp-2d5); }
  .vpa[data-vpa-size="s"] .vpa__tile-media { width: 42px; height: 42px; }
  .vpa[data-vpa-size="s"] .vpa__tag, .vpa[data-vpa-size="s"] .vpa__discount { font-size: 9px; padding: 2px 5.5px; }
  .vpa[data-vpa-size="s"] .vpa__chip, .vpa[data-vpa-size="s"] .vpa__tile-info { font-size: 10px; padding: 3px 7px; }
  .vpa[data-vpa-size="s"] .vpa__swatch { width: 58px; }
  .vpa[data-vpa-size="s"] .vpa__swatch-fill { width: 36px; height: 36px; }

  /* ─── M — Medium (default, no overrides) ───────────────────────── */
  /* The tightened baseline from the .vpa__tile rules is the M preset. */

  /* ─── Colour swatch layout + label modifiers ────────────────────── */
  /* Spread: distribute swatches evenly across the row (single line). */
  .vpa[data-vpa-color-layout="spread"] .vpa__choices--swatch {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: var(--sp-2);
    justify-items: center;
  }
  .vpa[data-vpa-color-layout="spread"] .vpa__swatch { width: 100%; max-width: 80px; }

  /* Label: hover — hide label inline, show as a styled tooltip on hover. */
  .vpa[data-vpa-color-label="hover"] .vpa__swatch-label {
    position: absolute;
    inset-inline-start: 50%;
    inset-block-start: calc(100% + 4px);
    transform: translateX(-50%);
    padding: 3px 8px;
    border-radius: 4px;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 10.5px;
    font-weight: var(--font-medium);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }
  .vpa[data-vpa-color-label="hover"] .vpa__swatch:hover .vpa__swatch-label,
  .vpa[data-vpa-color-label="hover"] .vpa__swatch:focus-within .vpa__swatch-label { opacity: 1; }

  /* Label: hidden — never render the label visually. */
  .vpa[data-vpa-color-label="hidden"] .vpa__swatch-label {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── L — Large / spacious ─────────────────────────────────────── */
  .vpa[data-vpa-size="l"] { gap: var(--sp-4); }
  .vpa[data-vpa-size="l"] .vpa__step { padding: var(--sp-5) var(--sp-5d5); }
  @media (min-width: 768px) { .vpa[data-vpa-size="l"] .vpa__step { padding: var(--sp-6) var(--sp-7); } }
  .vpa[data-vpa-size="l"] .vpa__head { margin-block-end: var(--sp-5); }
  .vpa[data-vpa-size="l"] .vpa__num { width: 32px; height: 32px; font-size: 14px; border-width: 2px; }
  .vpa[data-vpa-size="l"] .vpa__title { font-size: var(--text-lg); }
  @media (min-width: 768px) { .vpa[data-vpa-size="l"] .vpa__title { font-size: var(--text-xl); } }
  .vpa[data-vpa-size="l"] .vpa__choices--tile { gap: var(--sp-3d5); }
  .vpa[data-vpa-size="l"] .vpa__tile { padding: var(--sp-5); padding-block-start: var(--sp-7); border-width: 2px; }
  .vpa[data-vpa-size="l"] .vpa__tile-body { grid-template-columns: 64px minmax(0, 1fr); gap: var(--sp-3d5); }
  .vpa[data-vpa-size="l"] .vpa__tile-media { width: 64px; height: 64px; border-radius: 12px; }
  .vpa[data-vpa-size="l"] .vpa__tile-name { font-size: var(--text-base); }
  @media (min-width: 768px) { .vpa[data-vpa-size="l"] .vpa__tile-name { font-size: var(--text-lg); } }
  .vpa[data-vpa-size="l"] .vpa__tile-price { font-size: var(--text-base); gap: var(--sp-2); }
  .vpa[data-vpa-size="l"] .vpa__tag, .vpa[data-vpa-size="l"] .vpa__discount { font-size: 11px; padding: 3.5px 8px; top: var(--sp-3); }
  .vpa[data-vpa-size="l"] .vpa__tag { left: var(--sp-3d5); }
  .vpa[data-vpa-size="l"] .vpa__discount { right: var(--sp-3d5); }
  .vpa[data-vpa-size="l"] .vpa__chip, .vpa[data-vpa-size="l"] .vpa__tile-info { font-size: 12px; padding: 5px 10px; margin-block-start: var(--sp-2d5); }
  .vpa[data-vpa-size="l"] .vpa__chip .icon { width: 13px; height: 13px; }
  .vpa[data-vpa-size="l"] .vpa__swatch { width: 72px; gap: var(--sp-2); }
  .vpa[data-vpa-size="l"] .vpa__swatch-fill { width: 46px; height: 46px; }
  .vpa[data-vpa-size="l"] .vpa__swatch-label { font-size: 13px; }

</style>

<div class="vpa"
  id="{{ vpa_id }}"
  data-vpa-root
  data-vpa-size="{{ block.settings.size_preset | default: 'm' }}"
  data-vpa-color-layout="{{ block.settings.colour_layout | default: 'wrap' }}"
  data-vpa-color-label="{{ block.settings.colour_label | default: 'always' }}"
  data-form-id="{{ product_form_id }}"
  data-dynamic="{{ block.settings.enable_dynamic_variants }}"
  data-product-title="{{ product.title | escape }}"
  data-product-handle="{{ product.handle }}"
  data-section-id="{{ section_id }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%}
    ═══ Step rendering loop ════════════════════════════════════════
    Iterates through product.options_with_values. Each option gets a
    fieldset with a CSS `order` value derived from its name (colour=1,
    size=2, edition=3, anything else=10+). JS uses the same data
    attributes to renumber badges 1..N in display order.
  {%- endcomment -%}
  {%- for option in product.options_with_values -%}
    {%- liquid
      assign option_pos = forloop.index
      assign name_lower = option.name | downcase
      assign is_color = false
      assign is_size = false

      if name_lower contains 'color' or name_lower contains 'colour'
        assign display_order = 1
        assign is_color = true
        assign step_label = block.settings.step1_label | default: 'Pick your colour'
      elsif name_lower contains 'size'
        assign display_order = 2
        assign is_size = true
        assign step_label = block.settings.step2_label | default: 'Pick your size'
      elsif name_lower contains 'edition' or name_lower contains 'bundle' or name_lower contains 'version'
        assign display_order = 3
        assign step_label = block.settings.step3_label | default: 'Pick your edition'
      else
        assign display_order = option_pos | plus: 10
        assign step_label = 'Pick your ' | append: option.name | downcase
      endif

      assign render_swatches = block.settings.enable_color_swatches
    -%}

    {%- comment -%} Hide the colour step entirely if disabled via setting. {%- endcomment -%}
    {%- if is_color and block.settings.show_colour_buttons == false -%}{%- continue -%}{%- endif -%}

    <fieldset
      class="vpa__step{% if display_order > 1 %} vpa__step--locked{% endif %}"
      style="order: {{ display_order }};"
      data-step-num="{{ display_order }}"
      data-option-position="{{ option_pos }}"
      data-option-name="{{ option.name | escape }}"
      data-is-size="{{ is_size }}"
      data-is-color="{{ is_color }}"
    >
      <div class="vpa__head">
        <span class="vpa__num" data-num-label>{{ display_order }}</span>
        <span class="vpa__title">{{ step_label }}</span>
        <span class="vpa__status" data-status></span>
        {%- if is_size and size_chart != blank -%}
          <button type="button" class="vpa__size-chart-link" aria-controls="SizeChart-{{ vpa_id }}" aria-expanded="false">
            {%- render 'icon', icon: 'ruler', size: 'xs', class: 'stroke-1' -%}
            {{ 'products.general.size_chart' | t }}
          </button>
        {%- endif -%}
      </div>

      <div class="vpa__choices vpa__choices--{% if is_color and render_swatches %}swatch{% elsif is_color %}text{% else %}tile{% endif %}">
        {%- for value in option.values -%}
          {%- liquid
            assign value_string = value | default: value.name
            # Find all variants for this option value
            assign all_for_value = nil
            case option_pos
              when 1
                assign all_for_value = product.variants | where: 'option1', value_string
              when 2
                assign all_for_value = product.variants | where: 'option2', value_string
              when 3
                assign all_for_value = product.variants | where: 'option3', value_string
            endcase
            assign rep_variant = all_for_value | first

            assign rep_image = product.featured_image
            if rep_variant.featured_image != blank
              assign rep_image = rep_variant.featured_image
            endif

            assign rep_pre_order = rep_variant.metafields.custom[pre_order_key]
            assign rep_tile_info = rep_variant.metafields.custom.tile_info
            assign rep_qty = rep_variant.inventory_quantity | default: 0
            assign value_handle = value_string | handle
            assign input_id = vpa_id | append: '-' | append: option_pos | append: '-' | append: value_handle

            assign rep_discount_pct = 0
            if rep_variant.compare_at_price > rep_variant.price
              assign rep_discount_pct = rep_variant.compare_at_price | minus: rep_variant.price | times: 100.0 | divided_by: rep_variant.compare_at_price | round
            endif

            # Option value is "unavailable" only if NO variant with this value
            # is available AND none have a pre-order metafield for the active market.
            assign value_has_available = false
            for v in all_for_value
              if v.available
                assign value_has_available = true
                break
              endif
              if v.metafields.custom[pre_order_key] != blank
                assign value_has_available = true
                break
              endif
            endfor
            assign value_unavailable = false
            unless value_has_available
              assign value_unavailable = true
            endunless

            # Most Popular pill: server-side initial state; JS refines per-variant.
            assign show_most_popular = false
            if forloop.first and value_unavailable == false and block.settings.most_popular_label != blank and option.values.size > 1
              if rep_qty > most_popular_min_stock
                assign show_most_popular = true
              endif
            endif

            # Sold-out treatment only on Size step
            assign show_sold_out_treatment = false
            if is_size and value_unavailable
              assign show_sold_out_treatment = true
            endif
          -%}

          {%- if is_color and render_swatches -%}
            {%- comment -%}
              ─── Colour swatch ──────────────────────────────────────
              Resolution order: value.swatch.image (modern Shopify) →
              settings.swatch_config (name:filename or name:#hex) →
              variant.featured_image (when color_swatch_type=variant).
            {%- endcomment -%}
            {%- liquid
              assign sw_image_url = ''
              assign sw_bg = ''
              if value.swatch.image
                assign sw_image_url = value.swatch.image | image_url: width: 128
              elsif value.swatch.color
                assign sw_bg = value.swatch.color
              endif
              if sw_image_url == '' and sw_bg == '' and settings.swatch_config != blank
                assign value_lower = value_string | downcase
                assign cfg_lines = settings.swatch_config | newline_to_br | split: '<br />'
                for line in cfg_lines
                  assign parts = line | strip | split: ':'
                  assign nm = parts.first | downcase | strip
                  if nm == value_lower
                    assign cfg_val = parts.last | strip
                    if cfg_val contains '#'
                      assign sw_bg = cfg_val
                    else
                      if images[cfg_val] != blank
                        assign sw_image_url = images[cfg_val] | image_url: width: 128
                      elsif cfg_val contains '//cdn.shopify.com/'
                        assign sw_image_url = cfg_val
                      endif
                    endif
                    break
                  endif
                endfor
              endif
              if block.settings.color_swatch_type == 'variant' and rep_image != blank
                assign sw_image_url = rep_image | image_url: width: 128
                assign sw_bg = ''
              endif
            -%}
            {%- comment -%} Colour swatches are always clickable — stock/availability cascades through the size + edition steps. {%- endcomment -%}
            <label class="vpa__swatch" for="{{ input_id }}" title="{{ value_string | escape }}">
              <input type="radio" id="{{ input_id }}" name="vpa-{{ vpa_id }}-{{ option_pos }}" value="{{ value_string | escape }}" data-option-position="{{ option_pos }}" data-value="{{ value_string | escape }}" data-option-value="{{ value_string | escape }}" data-option-value-id="{{ value.id }}">
              <span class="vpa__swatch-fill" style="{% if sw_image_url != '' %}background-image: url('{{ sw_image_url }}');{% endif %}{% if sw_bg != '' %}background-color: {{ sw_bg }};{% else %}background-color: rgb(var(--color-foreground)/0.06);{% endif %}"></span>
              <span class="vpa__swatch-label">{{ value_string }}</span>
            </label>

          {%- elsif is_color -%}
            {%- comment -%} Colour text-button (when image swatches disabled) — always clickable too. {%- endcomment -%}
            <label class="vpa__text-btn" for="{{ input_id }}">
              <input type="radio" id="{{ input_id }}" name="vpa-{{ vpa_id }}-{{ option_pos }}" value="{{ value_string | escape }}" data-option-position="{{ option_pos }}" data-value="{{ value_string | escape }}" data-option-value="{{ value_string | escape }}" data-option-value-id="{{ value.id }}">
              {{ value_string }}
            </label>

          {%- else -%}
            {%- comment -%}
              ─── Tile card (Size / Edition / other) ─────────────────
              Both Sold Out and Most Popular tags are rendered when
              applicable. Visibility comes from rep_variant initially,
              then JS refines per-variant on every selection change.
            {%- endcomment -%}
            <label
              class="vpa__tile{% if show_sold_out_treatment %} vpa__tile--sold-out{% endif %}"
              for="{{ input_id }}"
              data-tile-option-position="{{ option_pos }}"
              data-tile-value="{{ value_string | escape }}"
              data-tile-is-size="{% if is_size %}true{% else %}false{% endif %}"
              data-tile-is-first="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              {%- if is_size and block.settings.sold_out_label != blank -%}
                <span class="vpa__tag vpa__tag--sold-out" data-sold-out{% unless show_sold_out_treatment %} hidden{% endunless %}>{{ block.settings.sold_out_label }}</span>
              {%- endif -%}
              {%- if forloop.first and block.settings.most_popular_label != blank and option.values.size > 1 -%}
                <span class="vpa__tag" data-most-popular{% unless show_most_popular %} hidden{% endunless %}>{{ block.settings.most_popular_label }}</span>
              {%- endif -%}
              {%- if rep_discount_pct > 0 and show_sold_out_treatment == false -%}
                <span class="vpa__discount">{{ rep_discount_pct }}% OFF</span>
              {%- endif -%}
              <input type="radio" id="{{ input_id }}" name="vpa-{{ vpa_id }}-{{ option_pos }}" value="{{ value_string | escape }}" data-option-position="{{ option_pos }}" data-value="{{ value_string | escape }}" data-option-value="{{ value_string | escape }}" data-option-value-id="{{ value.id }}"{% if value_unavailable %} disabled{% endif %}>
              <div class="vpa__tile-body">
                <div class="vpa__tile-media">
                  {%- if rep_image != blank -%}
                    {{ rep_image | image_url: width: 104 | image_tag: loading: 'lazy', alt: value_string }}
                  {%- endif -%}
                </div>
                <div class="vpa__tile-text">
                  <div class="vpa__tile-name">{{ value_string }}</div>
                  {%- if rep_variant -%}
                    <div class="vpa__tile-price">
                      <span>{{ rep_variant.price | money }}</span>
                      {%- if rep_variant.compare_at_price > rep_variant.price -%}
                        <del>{{ rep_variant.compare_at_price | money }}</del>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  {%- comment -%}
                    Pre-order chip — strip a leading "Pre Order"/"Pre-order" from
                    the metafield value so it doesn't double up with the chip prefix.
                  {%- endcomment -%}
                  {%- if block.settings.show_per_tile_chip -%}
                    {%- assign cleaned_pre_order = rep_pre_order | replace: 'Pre Order ', '' | replace: 'Pre-Order ', '' | replace: 'Pre-order ', '' | replace: 'pre order ', '' | replace: 'pre-order ', '' | replace: 'PreOrder ', '' | replace: 'preorder ', '' -%}
                    <span class="vpa__chip" data-pre-order-chip{% if rep_pre_order == blank %} hidden{% endif %}>
                      {%- render 'icon', icon: 'calendar', size: 'xs', class: 'icon' -%}
                      <span class="vpa__chip-text" data-pre-order-chip-text>
                        {%- if rep_pre_order != blank -%}
                          {%- if block.settings.pre_order_chip_prefix != blank %}{{ block.settings.pre_order_chip_prefix }} {% endif -%}{{ cleaned_pre_order }}
                        {%- endif -%}
                      </span>
                    </span>
                  {%- endif -%}

                  {%- comment -%} Energy-Saving Bundle blurb (auto-shown on matching value names). {%- endcomment -%}
                  {%- liquid
                    assign value_lc = value_string | downcase
                    assign is_energy_value = false
                    if value_lc contains 'energy' or value_lc contains 'saving' or value_lc contains 'eco'
                      assign is_energy_value = true
                    endif
                  -%}
                  {%- if is_energy_value and block.settings.energy_saving_text != blank -%}
                    <span class="vpa__tile-info">{{ block.settings.energy_saving_text }}</span>
                  {%- elsif rep_tile_info != blank -%}
                    <span class="vpa__tile-info">{{ rep_tile_info }}</span>
                  {%- endif -%}
                </div>
              </div>
            </label>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </fieldset>
  {%- endfor -%}

  {%- comment -%}
    ═══ Step 4 — Add-Ons ═════════════════════════════════════════════
    Hidden until all earlier steps have a value (JS reveals via
    [data-revealed]). Add-on rows render in original metafield order;
    priority keywords push matching entries to the top via CSS `order`.
  {%- endcomment -%}
  {%- if addons_enabled -%}
    {%- liquid
      assign priority_kw_raw = block.settings.addon_priority_keywords | default: ''
      assign priority_keywords = priority_kw_raw | downcase | split: ','
    -%}
    <fieldset class="vpa__step vpa__step--addons" style="order: 50;" data-addons-step aria-hidden="true">
      <div class="vpa__head">
        <span class="vpa__num" data-num-label>4</span>
        <span class="vpa__title">{{ block.settings.addons_heading | default: 'Popular Add-Ons' }}</span>
        <span class="vpa__status" data-status>{{ block.settings.addons_optional_label | default: 'Optional' }}</span>
      </div>
      <div class="vpa__addon-list">
        {%- for addon in popular_upgrades -%}
          {%- liquid
            assign addon_variant = addon.selected_or_first_available_variant
            assign addon_image = addon.featured_image
            assign addon_id = 'vpa-addon-' | append: vpa_id | append: '-' | append: forloop.index
            assign has_subs = false
            if addon.selling_plan_groups.size > 0
              assign has_subs = true
            endif

            # Score against pin-to-top keywords. First matching keyword wins;
            # its position becomes the CSS order. Non-matches → order 99.
            assign addon_title_lc = addon.title | downcase
            assign sort_order = 99
            for kw in priority_keywords
              assign kw_trim = kw | strip
              if kw_trim != blank and addon_title_lc contains kw_trim
                assign sort_order = forloop.index
                break
              endif
            endfor
          -%}
          <label class="vpa__addon" for="{{ addon_id }}" style="order: {{ sort_order }};" data-addon-handle="{{ addon.handle }}">
            <input type="checkbox" id="{{ addon_id }}" class="vpa__addon-check" data-addon-variant-id="{{ addon_variant.id }}" data-addon-price="{{ addon_variant.price }}">
            <div class="vpa__addon-media" data-addon-media>
              {%- if addon_image != blank -%}
                {{ addon_image | image_url: width: 96 | image_tag: loading: 'lazy', alt: addon.title }}
              {%- endif -%}
            </div>
            <div class="vpa__addon-name-wrap">
              <span class="vpa__addon-name">{{ addon.title }}</span>
              {%- if addon.variants.size > 1 -%}
                <span class="vpa__addon-variant" data-addon-variant-label>{{ addon_variant.title }}</span>
              {%- endif -%}
            </div>
            <span class="vpa__addon-price" data-addon-price-display>{{ addon_variant.price | money }}</span>

            {%- if has_subs -%}
              {%- comment -%}
                Subscription panel — plans rendered first so the browser
                pre-selects a subscription by default; "one-time" sits at
                the bottom as an opt-out. Plan name is verbatim (merchants
                put the discount in the name in the subs app).
              {%- endcomment -%}
              <div class="vpa__addon-sub">
                <div class="vpa__addon-sub-head">
                  <span class="vpa__addon-sub-savings">{{ block.settings.subscribe_savings_label | default: 'Subscribe & Save' }}</span>
                </div>
                {%- if block.settings.subscribe_description != blank -%}
                  <div class="vpa__addon-sub-desc">{{ block.settings.subscribe_description }}</div>
                {%- endif -%}
                <select class="vpa__addon-plan" aria-label="Delivery frequency for {{ addon.title | escape }}">
                  {%- for group in addon.selling_plan_groups -%}
                    {%- for plan in group.selling_plans -%}
                      <option value="{{ plan.id }}" data-selling-group="{{ group.id }}">{{ plan.name }}</option>
                    {%- endfor -%}
                  {%- endfor -%}
                  <option value="">{{ block.settings.addon_onetime_label | default: 'No, thanks — one-time only' }}</option>
                </select>
              </div>
            {%- endif -%}
          </label>
        {%- endfor -%}
      </div>
    </fieldset>
  {%- endif -%}
</div>

{%- comment -%}
  Fresh pre-order data block. JS reads this on every page load (and on
  every Section Rendering API refetch) so chip text stays in sync with
  the metafield even when the page HTML is served from CDN cache.
{%- endcomment -%}
<script type="application/json" data-vpa-preorder-map="{{ vpa_id }}">
{
  {%- assign _emit = false -%}
  {%- for v in product.variants -%}
    {%- assign po = v.metafields.custom[pre_order_key] -%}
    {%- if po != blank -%}{%- if _emit %},{% endif -%}"{{ v.id }}": {{ po | json }}{%- assign _emit = true -%}{%- endif -%}
  {%- endfor -%}
}
</script>

{%- comment -%} ═══ Size-chart modal (matches the theme's existing pattern) ═══ {%- endcomment -%}
{%- if size_chart != blank -%}
  <x-modal id="SizeChart-{{ vpa_id }}" class="x-modal drawer z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none" role="dialog" aria-modal="true" aria-label="{{ size_chart.title | escape }}" hidden>
    <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="SizeChart-{{ vpa_id }}" aria-expanded="false"></overlay-element>
    <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
      <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative" tabindex="0">
        <span class="drawer__title heading title-md">{{ size_chart.title | escape }}</span>
        <button class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center" type="button" is="hover-button" aria-controls="SizeChart-{{ vpa_id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">{%- render 'icon', icon: 'close', size: 'sm' -%}</span>
        </button>
      </gesture-element>
      <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
        <div class="drawer__scrollable relative flex flex-col gap-5 md:gap-7 grow shrink">
          <div class="rte text-base md:text-lg">{{ size_chart.content }}</div>
        </div>
      </div>
    </div>
  </x-modal>
{%- endif -%}

<script>
(function () {
  'use strict';
  var root = document.getElementById('{{ vpa_id }}');
  if (!root) return;

  // ═══ Constants & state ═══════════════════════════════════════════════
  var vpaId          = root.id;
  var optionCount    = {{ product.options.size }};
  var formId         = root.dataset.formId;
  var enableDynamic  = root.dataset.dynamic === 'true';
  var productHandle  = root.dataset.productHandle;
  var productTitle   = root.dataset.productTitle || '';
  var sectionId      = root.dataset.sectionId;
  var productId      = '{{ product.id }}';
  var galleryElId    = 'ProductGallery-' + sectionId + '-' + productId;
  var chipPrefix     = {{ block.settings.pre_order_chip_prefix | default: 'Pre-order · ships' | json }};
  var moneyFormat    = {{ shop.money_format | json }};
  var skuPrefixLength = {{ block.settings.addon_match_sku_prefix_length | default: 4 }};
  var skuMatchingEnabled = {{ block.settings.addon_match_by_sku_prefix | default: true }};
  var mostPopularMinStock = {{ most_popular_min_stock | default: 0 }};

  // Spa model token, auto-derived from product title (first word).
  // Used as a required keyword for add-ons with model-prefixed variants
  // like "Tahoe / 4 Person", "Garda / 4 Person", "Como / 6 Person".
  var spaModelToken = (productTitle.split(/\s+/)[0] || '').toLowerCase();
  if (spaModelToken.length < 3) spaModelToken = '';

  // Currently-resolved main spa variant — JS state, not the form's hidden
  // input (which is server-rendered disabled in this theme).
  var currentMainVariantId = {{ product.selected_or_first_available_variant.id }};

  // User's current option selections, keyed by Shopify option position (1..N).
  var selected = {};

  // ═══ Server-side data maps ═══════════════════════════════════════════
  // Each map uses a prefix-comma pattern so a blank-metafield entry can't
  // leave a trailing comma (which would break the inline script).
  var variants = {{ product.variants | json }};

  // variant id → pre-order date string (market-aware)
  var preOrderByVariant = {
    {%- assign _emit = false -%}
    {%- for v in product.variants -%}
      {%- assign po = v.metafields.custom[pre_order_key] -%}
      {%- if po != blank -%}{%- if _emit %},{% endif -%}"{{ v.id }}": {{ po | json }}{%- assign _emit = true -%}{%- endif -%}
    {%- endfor -%}
  };

  // variant id → featured image URL (for swapping tile media on colour change)
  var variantImageUrl = {
    {%- assign _emit = false -%}
    {%- for v in product.variants -%}
      {%- if v.featured_image -%}{%- if _emit %},{% endif -%}"{{ v.id }}": {{ v.featured_image | image_url: width: 208 | json }}{%- assign _emit = true -%}{%- endif -%}
    {%- endfor -%}
  };

  // variant id → inventory_quantity (for variant-level Most Popular gating)
  var inventoryByVariant = {
    {%- assign _emit = false -%}
    {%- for v in product.variants -%}
      {%- if _emit %},{% endif -%}"{{ v.id }}": {{ v.inventory_quantity | default: 0 }}{%- assign _emit = true -%}
    {%- endfor -%}
  };

  // variant id → SKU (for add-on SKU-prefix matching)
  var spaVariantSku = {
    {%- assign _emit = false -%}
    {%- for v in product.variants -%}
      {%- if _emit %},{% endif -%}"{{ v.id }}": {{ v.sku | default: '' | json }}{%- assign _emit = true -%}
    {%- endfor -%}
  };

  // variant id → first gang_media item. This theme stores per-variant media
  // in variant.metafields.theme.gang_media (a list), and the media-gallery
  // section reads it server-side. But the gallery's variant:change listener
  // only looks at variant.featured_media — so for variants that use
  // gang_media but not featured_media, the gallery wouldn't swap. We
  // surface the first gang_media item here and synthesise it as
  // featured_media when dispatching, so the gallery's setActiveMedia call
  // hits the right media id.
  var gangMediaByVariant = {
    {%- assign _emit = false -%}
    {%- for v in product.variants -%}
      {%- assign _gm = v.metafields.theme.gang_media.value -%}
      {%- if _gm and _gm.size > 0 -%}
        {%- if _emit %},{% endif -%}"{{ v.id }}": {{ _gm | first | json }}{%- assign _emit = true -%}
      {%- endif -%}
    {%- endfor -%}
  };

  // addon handle → variants[] (for resolving the right add-on variant per spa selection)
  var addonVariants = {
    {%- assign _emit_a = false -%}
    {%- for addon in popular_upgrades -%}
      {%- if _emit_a %},{% endif -%}
      {{ addon.handle | json }}: [
        {%- assign _emit_v = false -%}
        {%- for v in addon.variants -%}
          {%- if _emit_v %},{% endif -%}
          {
            "id": {{ v.id }},
            "title": {{ v.title | json }},
            "sku": {{ v.sku | default: '' | json }},
            "price": {{ v.price }},
            "available": {{ v.available }},
            "image": {% if v.featured_image %}{{ v.featured_image | image_url: width: 192 | json }}{% else %}null{% endif %}
          }
          {%- assign _emit_v = true -%}
        {%- endfor -%}
      ]
      {%- assign _emit_a = true -%}
    {%- endfor -%}
  };

  // ═══ Schema-driven match tables (parsed from textarea settings) ══════
  function parseKVLines(text, valueTransform) {
    var map = {};
    String(text || '').split('\n').forEach(function (line) {
      var idx = line.indexOf(':');
      if (idx === -1) return;
      var k = line.slice(0, idx).trim();
      var v = line.slice(idx + 1).trim();
      if (k && v) map[k.toLowerCase()] = valueTransform ? valueTransform(v) : v;
    });
    return map;
  }

  // Explicit spa-SKU → add-on-SKU map. Keys & values stored UPPER for case-insensitive matching.
  var skuExplicitMap = {};
  String({{ block.settings.addon_sku_match_map | default: '' | json }}).split('\n').forEach(function (line) {
    var idx = line.indexOf(':');
    if (idx === -1) return;
    var k = line.slice(0, idx).trim().toUpperCase();
    var v = line.slice(idx + 1).trim().toUpperCase();
    if (k && v) skuExplicitMap[k] = v;
  });
  // Longest-pattern-first so specific entries override broad ones.
  var skuExplicitKeys = Object.keys(skuExplicitMap).sort(function (a, b) { return b.length - a.length; });

  // Fallback keyword map for non-SKU matching: spa size value → comma-separated keywords.
  var addonMatchMap = parseKVLines({{ block.settings.addon_variant_match_map | default: '' | json }});

  // ═══ Cached DOM references ═══════════════════════════════════════════
  var addonsStepEl = root.querySelector('[data-addons-step]');
  var sizeStepEl   = root.querySelector('.vpa__step[data-is-size="true"]');
  var sizeOptionPos = sizeStepEl ? +sizeStepEl.dataset.optionPosition : null;

  // ═══ Utilities ═══════════════════════════════════════════════════════
  function formatMoney(cents) {
    var n = (cents / 100).toFixed(2);
    var withCommas = String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    return moneyFormat
      .replace(/\{\{\s*amount\s*\}\}/g, withCommas)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, Math.round(cents / 100))
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, withCommas)
      .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/g, Math.round(cents / 100))
      .replace(/<[^>]*>/g, ''); // strip HTML so textContent renders the glyph not markup
  }

  // ═══ Variant resolution ═════════════════════════════════════════════
  // Variant that matches ALL current selections (used for the main spa variant).
  function findVariant() {
    return variants.find(function (v) {
      for (var i = 1; i <= optionCount; i++) {
        if (selected[i] !== v['option' + i]) return false;
      }
      return true;
    });
  }

  // Variant that matches a tile's option value + the user's OTHER selections
  // (used for per-tile chip/image/Most-Popular evaluation).
  function variantForTile(pos, value) {
    return variants.find(function (v) {
      if (v['option' + pos] !== value) return false;
      for (var i = 1; i <= optionCount; i++) {
        if (i === pos) continue;
        if (selected[i] && selected[i] !== v['option' + i]) return false;
      }
      return true;
    });
  }

  // ═══ UI updaters — keep DOM in sync with `selected` ══════════════════
  function updateAvailability() {
    if (!enableDynamic) return;
    root.querySelectorAll('input[data-option-position]').forEach(function (input) {
      // Colour step is always interactive — stock/availability cascades
      // through size + edition rather than locking colour choices.
      var step = input.closest('.vpa__step');
      if (step && step.dataset.isColor === 'true') return;

      var pos = +input.dataset.optionPosition;
      var value = input.dataset.value;
      var possible = variants.some(function (v) {
        // Selectable if available in stock, back-orderable, OR has a pre-order date.
        if (!v.available && !preOrderByVariant[v.id]) return false;
        if (v['option' + pos] !== value) return false;
        for (var i = 1; i <= optionCount; i++) {
          if (i === pos) continue;
          if (selected[i] && selected[i] !== v['option' + i]) return false;
        }
        return true;
      });
      var label = input.closest('label');
      if (label) label.classList.toggle('vpa__choice--unavailable', !possible);
      input.disabled = !possible;
    });
  }

  // Lock later steps until earlier steps have a value; renumber badges in
  // display order; reveal/hide the Add-Ons step.
  function renumberAndLock() {
    var optionSteps = Array.prototype.slice
      .call(root.querySelectorAll('.vpa__step[data-option-position]'))
      .sort(function (a, b) { return +a.dataset.stepNum - +b.dataset.stepNum; });

    var allChosen = true;
    optionSteps.forEach(function (step, i) {
      var pos = +step.dataset.optionPosition;
      var prevAllChosen = i === 0 || optionSteps.slice(0, i).every(function (s) { return selected[+s.dataset.optionPosition]; });
      var chosen = selected[pos];

      step.classList.toggle('vpa__step--locked', !prevAllChosen);
      step.classList.toggle('vpa__step--complete', !!chosen);

      var num = step.querySelector('[data-num-label]');
      if (num) num.textContent = i + 1;
      var status = step.querySelector('[data-status]');
      if (status && !/optional/i.test(status.textContent)) status.textContent = chosen || '';

      if (!chosen) allChosen = false;
    });

    if (addonsStepEl) {
      if (allChosen) {
        addonsStepEl.setAttribute('data-revealed', 'true');
        addonsStepEl.setAttribute('aria-hidden', 'false');
      } else {
        addonsStepEl.removeAttribute('data-revealed');
        addonsStepEl.setAttribute('aria-hidden', 'true');
      }
      var addonsNum = addonsStepEl.querySelector('[data-num-label]');
      if (addonsNum) addonsNum.textContent = optionSteps.length + 1;
    }
    return allChosen;
  }

  // Per-tile UI: pre-order chip text, variant image swap, Most Popular pill,
  // Sold Out treatment. All evaluated at the variant resolved for the tile
  // under the user's current selections (not the colour-level rep variant).
  function updateTilePreOrderChip(label, variant) {
    var chip = label.querySelector('[data-pre-order-chip]');
    if (!chip) return;
    // Text node lives in a child span so the calendar icon next to it
    // isn't wiped on every update.
    var textEl = chip.querySelector('[data-pre-order-chip-text]') || chip;
    var date = variant ? preOrderByVariant[variant.id] : null;
    if (date) {
      // Strip a leading "Pre-order"/"Pre order"/"Preorder" so the prefix doesn't double up.
      var cleaned = String(date).replace(/^(pre[\s-]*order)[\s:\-—·,]*/i, '').trim();
      textEl.textContent = (chipPrefix ? chipPrefix + ' ' : '') + cleaned;
      chip.hidden = false;
    } else {
      textEl.textContent = '';
      chip.hidden = true;
    }
  }

  function updateTileMedia(label, variant) {
    if (!variant) return;
    var img = label.querySelector('.vpa__tile-media img');
    if (!img) return;
    var url = variantImageUrl[variant.id];
    if (url && img.src !== url) {
      img.src = url;
      img.removeAttribute('srcset');
      img.removeAttribute('data-src');
    }
  }

  function updateTilePills(label, variant, opts) {
    var hasPreOrder = variant ? !!preOrderByVariant[variant.id] : false;
    var sellable = variant ? (variant.available || hasPreOrder) : false;
    var soldOut = !sellable;

    // Sold-out treatment is Size-step only.
    var soldOutTag = label.querySelector('[data-sold-out]');
    if (soldOutTag) soldOutTag.hidden = !(opts.isSize && soldOut);
    label.classList.toggle('vpa__tile--sold-out', opts.isSize && soldOut);

    // Most Popular: first-of-its-option, sellable, inventory > threshold, not sold out.
    var mostPopTag = label.querySelector('[data-most-popular]');
    if (mostPopTag) {
      var qty = variant ? (inventoryByVariant[variant.id] || 0) : 0;
      var show = opts.isFirst && sellable && qty > mostPopularMinStock && !(opts.isSize && soldOut);
      mostPopTag.hidden = !show;
    }
  }

  function updateAllTiles() {
    root.querySelectorAll('label[data-tile-option-position]').forEach(function (label) {
      var pos = +label.dataset.tileOptionPosition;
      var value = label.dataset.tileValue;
      var variant = variantForTile(pos, value);
      updateTilePreOrderChip(label, variant);
      updateTileMedia(label, variant);
      updateTilePills(label, variant, {
        isSize:  label.dataset.tileIsSize === 'true',
        isFirst: label.dataset.tileIsFirst === 'true'
      });
    });
  }

  // Fire the variant:change event the theme's media gallery + other PDP
  // blocks listen for. Works for any variant — full match or partial.
  // If the variant lacks Shopify's built-in featured_media but has the
  // theme's per-variant gang_media metafield, synthesise a featured_media
  // from the first gang_media item so the gallery's setActiveMedia call
  // still finds the right media id and swaps the hero image.
  function dispatchVariantChange(variant) {
    if (!variant) return;
    if (!variant.featured_media && gangMediaByVariant[variant.id]) {
      var gm = gangMediaByVariant[variant.id];
      variant = Object.assign({}, variant, {
        featured_media: { id: gm.id, alt: gm.alt, position: gm.position, preview_image: gm.preview_image, media_type: gm.media_type }
      });
    }
    var form = document.getElementById(formId);
    if (!form) return;
    form.dispatchEvent(new CustomEvent('variant:change', {
      bubbles: true,
      detail: { variant: variant }
    }));
  }

  // First variant compatible with the user's current selections (any subset).
  // Used to surface a representative image for the gallery / price block
  // while the user is still mid-flow (e.g. has only picked colour so far).
  function findFirstCompatibleVariant() {
    return variants.find(function (v) {
      for (var i = 1; i <= optionCount; i++) {
        if (selected[i] && selected[i] !== v['option' + i]) return false;
      }
      return true;
    });
  }

  // Sync the host form's hidden id input AND fire variant:change. Only
  // call this when we have a full, valid variant.
  function syncFormVariant(variant) {
    if (!variant) return;
    currentMainVariantId = variant.id;
    var form = document.getElementById(formId);
    if (!form) return;
    var idInput = form.querySelector('input[name="id"]');
    if (idInput && idInput.value != variant.id) {
      idInput.value = variant.id;
      idInput.dispatchEvent(new Event('change', { bubbles: true }));
    }
    dispatchVariantChange(variant);
  }

  // ═══ Add-on variant matching ═════════════════════════════════════════
  // Three-stage cascade: explicit SKU map → SKU prefix → keyword/title.

  function matchAddonBySkuExplicit(list, spaSku) {
    for (var i = 0; i < skuExplicitKeys.length; i++) {
      var key = skuExplicitKeys[i];
      if (spaSku.indexOf(key) !== 0) continue;
      var targetSku = skuExplicitMap[key];
      var hit = null;
      list.forEach(function (v) {
        if (hit || !v.sku) return;
        if (v.sku.toUpperCase() === targetSku) hit = v;
      });
      if (hit) return hit;
    }
    return null;
  }

  function matchAddonBySkuPrefix(list, spaSku) {
    var maxLen = Math.min(skuPrefixLength, spaSku.length);
    for (var len = maxLen; len >= 3; len--) {
      var prefix = spaSku.slice(0, len);
      var hit = null;
      list.forEach(function (v) {
        if (hit || !v.sku) return;
        if (v.sku.toUpperCase().slice(0, len) === prefix) hit = v;
      });
      if (hit) return hit;
    }
    return null;
  }

  function pickAddonVariantBySku(list) {
    if (!skuMatchingEnabled) return null;
    var spaSku = (spaVariantSku[currentMainVariantId] || '').toUpperCase();
    if (spaSku.length < 3) return null;
    // Note: NO availability filter here — we want the right variant even if
    // it's out of stock. The UI hides the row when the matched variant is
    // sold out, rather than mis-matching to a wrong-model alternative.
    return matchAddonBySkuExplicit(list, spaSku) || matchAddonBySkuPrefix(list, spaSku);
  }

  function matchAddonByKeyword(list) {
    var spaSize = sizeOptionPos ? selected[sizeOptionPos] : null;
    if (!spaSize) return null;
    var spaSizeLc = spaSize.toLowerCase();

    // Keyword source: explicit map entry > auto-tokenise on | / , em-dash.
    var raw = addonMatchMap[spaSizeLc];
    var sizeKeywords;
    if (raw) {
      sizeKeywords = raw.split(',').map(function (s) { return s.trim().toLowerCase(); }).filter(Boolean);
    } else {
      sizeKeywords = spaSizeLc.split(/[|/,—]+/).map(function (t) { return t.trim(); }).filter(function (t) { return t.length >= 2; });
    }
    if (sizeKeywords.length === 0) return null;

    // If the add-on has model-prefixed variants (e.g. Tahoe / 4 Person),
    // require a model match. If our model isn't among them (e.g. Pacific
    // on a foam-tub-only cover), bail to avoid wrong-model matches.
    var anyVariantHasModel = spaModelToken && list.some(function (v) { return v.title.toLowerCase().indexOf(spaModelToken) >= 0; });
    var requireModelMatch = anyVariantHasModel;
    if (!requireModelMatch && spaModelToken) {
      var hasModelPrefixDelim = list.some(function (v) { return /[\/|]/.test(v.title); });
      if (hasModelPrefixDelim) return null;
    }

    var best = null;
    var bestScore = 0;
    list.forEach(function (v) {
      if (!v.available) return;
      var titleLc = v.title.toLowerCase();
      var hasModelMatch = spaModelToken ? titleLc.indexOf(spaModelToken) >= 0 : false;
      if (requireModelMatch && !hasModelMatch) return;
      var sizeScore = sizeKeywords.reduce(function (acc, kw) { return acc + (titleLc.indexOf(kw) >= 0 ? 1 : 0); }, 0);
      if (requireModelMatch && sizeScore === 0) return; // require size too once model matches
      var score = sizeScore + (hasModelMatch ? 2 : 0); // model match weighted heavier
      if (score > bestScore) { bestScore = score; best = v; }
    });
    return bestScore > 0 ? best : null;
  }

  function pickAddonVariant(handle) {
    var list = addonVariants[handle];
    if (!list || list.length < 2) return null;
    return pickAddonVariantBySku(list) || matchAddonByKeyword(list);
  }

  // Apply the matched variant to an add-on row + enforce in-stock-only.
  // Runs for every add-on row regardless of whether a better variant match
  // was found, so single-variant and unmatched add-ons also get hidden when
  // their currently-assigned variant is out of stock.
  function applyAddonMatch(addonEl) {
    var handle = addonEl.dataset.addonHandle;
    if (!handle) return;
    var list = addonVariants[handle];
    if (!list || list.length === 0) return;

    var check = addonEl.querySelector('.vpa__addon-check');
    var priceEl = addonEl.querySelector('[data-addon-price-display]');
    var labelEl = addonEl.querySelector('[data-addon-variant-label]');
    var mediaEl = addonEl.querySelector('[data-addon-media]');

    // Try to match a better variant for the current spa selection (only
    // makes sense for multi-variant add-ons).
    var matched = list.length > 1 ? pickAddonVariant(handle) : null;
    if (matched) {
      if (check && check.dataset.addonVariantId != matched.id) {
        check.dataset.addonVariantId = matched.id;
        check.dataset.addonPrice = matched.price;
      }
      if (priceEl) priceEl.textContent = formatMoney(matched.price);
      if (labelEl) labelEl.textContent = matched.title;
      if (mediaEl && matched.image) {
        var img = mediaEl.querySelector('img');
        if (img) {
          if (img.src !== matched.image) {
            img.src = matched.image;
            img.removeAttribute('srcset');
            img.removeAttribute('data-src');
          }
        } else {
          var newImg = document.createElement('img');
          newImg.src = matched.image;
          newImg.loading = 'lazy';
          newImg.alt = matched.title;
          mediaEl.appendChild(newImg);
        }
      }
    }

    // Look up the variant the row is currently pointing at (matched or
    // server-rendered default) and hide the row if it's out of stock.
    var currentId = check ? parseInt(check.dataset.addonVariantId, 10) : null;
    var current = null;
    for (var i = 0; i < list.length; i++) {
      if (list[i].id === currentId) { current = list[i]; break; }
    }
    if (!current) current = list[0];

    var isSoldOut = !current.available;
    addonEl.hidden = isSoldOut;
    if (check) {
      check.disabled = isSoldOut;
      if (isSoldOut) check.checked = false;
    }
  }

  function applyAllAddonMatches() {
    root.querySelectorAll('label.vpa__addon').forEach(applyAddonMatch);
  }

  // Self-contained gallery swap on selection — same mechanism the standard
  // variant_picker block uses (Section Rendering API with option_values),
  // but driven directly rather than via theme.pubsub + ProductInfo, so this
  // works regardless of how the host section is wired up.
  var lastGalleryFetch = '';
  var galleryAbort = null;
  function refreshGalleryFromServer() {
    if (!sectionId || !productHandle) return;
    var checked = root.querySelectorAll('input[data-option-value-id]:checked');
    var ids = Array.prototype.map.call(checked, function (el) {
      return el.getAttribute('data-option-value-id');
    }).filter(Boolean);
    if (!ids.length) return;
    var key = ids.join(',');
    if (key === lastGalleryFetch) return;
    lastGalleryFetch = key;

    var url = '/products/' + productHandle + '?section_id=' + encodeURIComponent(sectionId) + '&option_values=' + encodeURIComponent(key);
    if (galleryAbort) galleryAbort.abort();
    galleryAbort = new AbortController();
    fetch(url, { credentials: 'same-origin', signal: galleryAbort.signal })
      .then(function (r) { return r.ok ? r.text() : null; })
      .then(function (html) {
        if (!html) return;
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var source = doc.getElementById(galleryElId);
        var dest = document.getElementById(galleryElId);
        if (!source || !dest) {
          if (window.console) console.warn('[vpa] gallery swap skipped — source/dest missing', { srcFound: !!source, destFound: !!dest, galleryElId: galleryElId });
          return;
        }
        dest.innerHTML = source.innerHTML;
        dest.removeAttribute('hidden');
        // Fire variant:change so other listeners (price, badges, etc.) react.
        // media-gallery's onVariantChanged calls setActiveMedia against the
        // freshly-rendered media list. Use full variant when available;
        // otherwise a representative match for the current partial selection.
        var v = findVariant() || findFirstCompatibleVariant();
        if (v) dispatchVariantChange(v);
      })
      .catch(function (err) {
        if (err && err.name === 'AbortError') return;
        if (window.console) console.error('[vpa] gallery refetch failed', err);
      });
  }

  // ═══ Event handlers ══════════════════════════════════════════════════
  root.addEventListener('change', function (e) {
    var input = e.target.closest('input[data-option-position]');
    if (!input) return;

    selected[+input.dataset.optionPosition] = input.dataset.value;
    updateAvailability();
    renumberAndLock();
    updateAllTiles();
    // Resolve the variant FIRST so the SKU-matcher reads the fresh id when
    // running add-on matching (otherwise every selection is off-by-one).
    var fullVariant = findVariant();
    if (fullVariant) {
      syncFormVariant(fullVariant);
    } else {
      // Partial selection (e.g. user has only picked colour so far). The
      // form's hidden id stays at the last-committed value, but we still
      // fire variant:change with a representative variant matching the
      // current selections — that's what triggers the media gallery to
      // swap its hero image, the price block to refresh, etc.
      var representative = findFirstCompatibleVariant();
      if (representative) dispatchVariantChange(representative);
    }
    applyAllAddonMatches();
    // Fetch the freshly-rendered section and swap in the new ProductGallery
    // HTML. Same mechanism the standard variant_picker block uses, just
    // driven directly so it doesn't depend on ProductInfo's pubsub wiring.
    refreshGalleryFromServer();
  });

  // Size-chart trigger
  var sizeChartBtn = root.querySelector('.vpa__size-chart-link');
  if (sizeChartBtn) {
    sizeChartBtn.addEventListener('click', function () {
      var modal = document.getElementById('SizeChart-{{ vpa_id }}');
      if (!modal) return;
      modal.hidden = false;
      modal.setAttribute('aria-expanded', 'true');
    });
  }

  // ═══ Cart submission ═════════════════════════════════════════════════
  // Capture-phase intercept on the Add to Cart button click. The buy_buttons
  // form is a `<form is="product-form">` custom element with its own submit
  // handler; intercepting at the click stage runs before that handler. When
  // add-ons are checked we route through /cart/add.js. With no add-ons we
  // let the native product-form flow run untouched.

  function buildCartItems(form) {
    var qty = 1;
    if (form) {
      var qtyInput = form.querySelector('input[name="quantity"]:not([disabled])');
      if (qtyInput && qtyInput.value) qty = parseInt(qtyInput.value, 10) || 1;
    }
    var items = [{ id: currentMainVariantId, quantity: qty }];
    root.querySelectorAll('.vpa__addon-check:checked').forEach(function (a) {
      var vid = parseInt(a.dataset.addonVariantId, 10);
      if (!vid) return;
      var item = { id: vid, quantity: 1 };
      var wrap = a.closest('.vpa__addon');
      var planSelect = wrap ? wrap.querySelector('.vpa__addon-plan') : null;
      if (planSelect && planSelect.value) item.selling_plan = parseInt(planSelect.value, 10);
      items.push(item);
    });
    return items;
  }

  function showCartError(message) {
    var existing = root.querySelector('[data-vpa-error]');
    if (existing) existing.remove();
    var el = document.createElement('div');
    el.setAttribute('data-vpa-error', '');
    el.style.cssText = 'margin: var(--sp-3) 0; padding: var(--sp-3) var(--sp-4); background: rgb(254 226 226); color: rgb(127 29 29); border-radius: 8px; font-size: 14px;';
    el.textContent = message;
    root.appendChild(el);
  }

  // Option B for 3rd-party app compatibility (VEX Auto Add, upsell apps,
  // free-gift apps, etc.):
  //
  //   1. Add the add-ons via /cart/add.js up-front (sequential — Shopify's
  //      bulk endpoint can silently drop selling_plan items in mixed batches).
  //   2. Dispatch cart events so app cart-watchers fire.
  //   3. Programmatically submit the host form via requestSubmit() so the
  //      browser fires a real `submit` event — every app/theme listener
  //      runs exactly as if the user had clicked Add to Cart normally, and
  //      the form's standard post handles the main variant + navigation.
  //
  // Net effect: VEX and similar apps see the exact same add-to-cart flow
  // they always see — we just front-load our add-ons before the form runs.

  function addOnsToCart(items) {
    var chain = Promise.resolve();
    var failed = null;
    items.forEach(function (item) {
      chain = chain.then(function () {
        if (failed) return;
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(item),
          credentials: 'same-origin'
        }).then(function (res) {
          if (res.ok) return;
          return res.json().then(function (err) {
            failed = { item: item, err: err };
            console.error('VPA /cart/add.js failed:', item, err);
          });
        });
      });
    });
    return chain.then(function () { return failed; });
  }

  function dispatchCartEvents(items) {
    var detail = { source: 'variant-picker-advanced', itemCount: items.length };
    ['cart:updated', 'cart:refresh', 'cart:added', 'cart:change'].forEach(function (name) {
      document.documentElement.dispatchEvent(new CustomEvent(name, { bubbles: true, detail: detail }));
    });
  }

  function submitAddOnsThenForm(form, originatingBtn) {
    // Collect only the add-on items (main variant goes through the standard
    // form submission, so VEX & co. see Shopify's normal add-to-cart flow).
    var addOnItems = [];
    root.querySelectorAll('.vpa__addon-check:checked').forEach(function (a) {
      var vid = parseInt(a.dataset.addonVariantId, 10);
      if (!vid) return;
      var item = { id: vid, quantity: 1 };
      var wrap = a.closest('.vpa__addon');
      var planSelect = wrap ? wrap.querySelector('.vpa__addon-plan') : null;
      if (planSelect && planSelect.value) item.selling_plan = parseInt(planSelect.value, 10);
      addOnItems.push(item);
    });

    if (originatingBtn) {
      originatingBtn.disabled = true;
      originatingBtn.setAttribute('aria-busy', 'true');
    }

    addOnsToCart(addOnItems).then(function (failed) {
      if (failed) {
        showCartError(failed.err.description || failed.err.message || 'Could not add add-on to cart.');
        if (originatingBtn) {
          originatingBtn.disabled = false;
          originatingBtn.removeAttribute('aria-busy');
        }
        return;
      }
      dispatchCartEvents(addOnItems);
      // Trigger the form's real submit event so any app or theme listener
      // (VEX, the product-form custom element, analytics, etc.) runs exactly
      // as if the user had clicked Add to Cart with no add-ons selected.
      // requestSubmit() fires the submit event; submit() does NOT.
      try {
        if (typeof form.requestSubmit === 'function') {
          form.requestSubmit(originatingBtn || undefined);
        } else {
          form.submit();
        }
      } catch (err) {
        console.error('VPA form submit failed:', err);
        // Last-resort fallback: redirect to /cart so the user at least lands
        // somewhere sensible with the add-ons we added.
        window.location.href = '/cart';
      }
    }).catch(function (err) {
      console.error('VPA cart submit error:', err);
      showCartError('Network error adding to cart.');
      if (originatingBtn) {
        originatingBtn.disabled = false;
        originatingBtn.removeAttribute('aria-busy');
      }
    });
  }

  document.addEventListener('click', function (e) {
    var btn = e.target && e.target.closest ? e.target.closest('button[type="submit"], input[type="submit"]') : null;
    if (!btn) return;
    // Resolve associated form via the button's HTML form property (covers
    // both DOM-nested buttons and buttons using the form="..." attribute).
    var form = btn.form || btn.closest('form');
    var btnFormAttr = btn.getAttribute('form');
    if (!form && !btnFormAttr) return;
    if ((!form || form.id !== formId) && btnFormAttr !== formId) return;

    var addonsChecked = root.querySelectorAll('.vpa__addon-check:checked');
    if (addonsChecked.length === 0) return; // no add-ons → standard flow, no intercept needed

    // preventDefault only — let other click listeners on the button
    // (analytics, upsell apps, etc.) still fire. We re-trigger the form's
    // submit event ourselves via requestSubmit once our add-ons land.
    e.preventDefault();
    submitAddOnsThenForm(form || document.getElementById(formId), btn);
  }, true /* capture */);

  // ═══ Live pre-order data refresh ═════════════════════════════════════
  // The pre-order chip's metafield value is baked into the HTML at render
  // time and Shopify's CDN caches PDPs for anonymous visitors. To keep the
  // chip in sync with the live metafield, we refetch this section via the
  // Section Rendering API (with a cache-bust query) on every page load and
  // update the in-memory preOrderByVariant map from the fresh JSON blob.

  function loadPreOrderMapFromDocument(docLike) {
    var sel = '[data-vpa-preorder-map="' + vpaId + '"]';
    var el = docLike.querySelector(sel);
    if (!el) return null;
    try {
      return JSON.parse(el.textContent);
    } catch (e) {
      return null;
    }
  }

  function refreshPreOrderFromServer() {
    if (!sectionId || !productHandle) return;
    var url = '/products/' + productHandle + '?section_id=' + encodeURIComponent(sectionId) + '&_=' + Date.now();
    fetch(url, { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.text() : null; })
      .then(function (html) {
        if (!html) return;
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var fresh = loadPreOrderMapFromDocument(doc);
        if (!fresh) return;
        // Replace map in-place so closures over preOrderByVariant pick up new values.
        Object.keys(preOrderByVariant).forEach(function (k) { delete preOrderByVariant[k]; });
        Object.keys(fresh).forEach(function (k) { preOrderByVariant[k] = fresh[k]; });
        updateAllTiles();
      })
      .catch(function () { /* network failure → keep server-rendered values */ });
  }

  // ═══ Initial paint ═══════════════════════════════════════════════════
  // Belt-and-braces: strip any stale "unavailable" state from colour
  // swatches/buttons. Earlier server versions added the class when all
  // variants for a colour were sold out; we now want colour always
  // clickable, so clear any cached HTML that came in with the class set.
  root.querySelectorAll('.vpa__step[data-is-color="true"] label').forEach(function (l) {
    l.classList.remove('vpa__choice--unavailable');
  });
  root.querySelectorAll('.vpa__step[data-is-color="true"] input[disabled]').forEach(function (i) {
    i.disabled = false;
  });

  updateAvailability();
  renumberAndLock();
  updateAllTiles();
  applyAllAddonMatches();
  refreshPreOrderFromServer();
})();
</script>
{%- endunless -%}
