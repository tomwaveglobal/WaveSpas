{%- doc -%}
  Static product card for a Mega Bundle item. Mirrors the look of
  product-card-bundle (media, badges, title, price) but renders a
  merchant-pre-selected variant instead of a customer variant picker.

  @param {object} product - the bundle item's product
  @param {object} variant - the resolved (chosen) variant to display + price
  @param {number} [qty] - quantity of this item in the bundle
  @param {string} [image_ratio] - media aspect ratio preset
  @param {boolean} [image_fill] - crop images to fill
  @param {boolean} [show_vendor] - display vendor
  @param {boolean} [show_sold_out] - show sold-out badge
  @param {boolean} [show_save_amount] - show savings badge
  @param {string} [save_type] - savings calculation type
{%- enddoc -%}

{%- liquid
  assign featured_media = variant.featured_image | default: product.featured_image
-%}
<div class="card product-card product-card--{{ settings.card_style }}{% if settings.card_border_thickness > 0 %} product-card--thickness{% endif %}{% unless featured_media %} no-media{% endunless %} flex flex-col leading-none relative">
  {%- if featured_media -%}
    <div class="product-card__media relative h-auto">
      {%- render 'product-badges',
        product: product,
        show_sold_out: show_sold_out,
        show_save_amount: show_save_amount,
        save_type: save_type,
        class: 'z-2 absolute grid gap-3 pointer-events-none'
      -%}
      <a class="block relative media media--{{ image_ratio }}{% unless image_fill %} media--contain{% endunless %} overflow-hidden" href="{{ product.url }}" aria-hidden="true" tabindex="-1">
        {{- featured_media | image_url: width: featured_media.width | image_tag: loading: 'lazy', widths: '180,360,540,720', sizes: '(min-width: 750px) 25vw, 90vw', alt: product.title -}}
      </a>
    </div>
  {%- else -%}
    <div class="product-card__media h-auto overflow-hidden">
      <span class="block aspect-{{ image_ratio }}"></span>
    </div>
  {%- endif -%}

  <div class="product-card__content grow flex flex-col justify-start text-{{ settings.card_text_alignment }}">
    {%- if show_vendor and product.vendor != blank -%}
      <div class="product-card__top w-full">
        <span class="caption uppercase leading-none tracking-widest">{{ product.vendor }}</span>
      </div>
    {%- endif -%}

    <div class="product-card__details flex flex-col gap-2 w-full">
      <p>
        <a class="product-card__title reversed-link text-base-xl font-medium leading-tight" href="{{ product.url }}">
          {{- product.title | escape -}}
        </a>
      </p>

      {%- unless product.has_only_default_variant -%}
        <span class="text-xs text-opacity leading-tight">{{ variant.title }}</span>
      {%- endunless -%}

      <div>
        {%- render 'product-price', product: product, variant: variant, use_variant: true, class: 'flex flex-wrap gap-2 md:gap-1d5' -%}
        {%- if qty and qty > 1 -%}
          <span class="text-xs text-opacity leading-tight">&times; {{ qty }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
