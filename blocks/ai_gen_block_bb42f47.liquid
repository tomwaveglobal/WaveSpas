      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "section_title_color",
      "label": "Section title",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "excerpt_color",
      "label": "Excerpt text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta text",
      "default": "#999999"
    }
  ],
  "presets": [
    {
      "name": "Knowledge base search"
    }
  ]
}
{% endschema %}