        "liquid": "{%- comment -%} Contona Room Visualiser {%- endcomment -%}\n<script type=\"application/json\" data-contona-product>\n  {\n    \"id\": {{ product.id | json }},\n    \"title\": {{ product.title | json }},\n    \"description\": {{ product.description | strip_html | truncate: 500 | json }},\n    \"type\": {{ product.type | json }},\n    \"vendor\": {{ product.vendor | json }},\n    \"tags\": {{ product.tags | json }},\n    \"collections\": [{%- for c in product.collections -%}\"{{ c.handle }}\"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],\n    \"price\": \"{{ product.price | money_without_currency }}\",\n    \"url\": \"{{ product.url }}\",\n    \"images\": [{%- for img in product.images limit:5 -%}{\"url\":{{ img | image_url: width: 1024 | json }},\"label\":{{ img.alt | default: 'image' | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],\n    \"variants\": [{%- for v in product.variants -%}{\"id\":{{ v.id | json }},\"label\":{{ v.title | json }},\"image\":{{ v.featured_image | default: product.featured_image | image_url: width: 1024 | json }},\"price\":{{ v.price | money | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]\n  }\n</script>",
