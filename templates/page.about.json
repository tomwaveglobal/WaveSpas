      "blocks": {
        "content_QFfdhK": {
          "type": "content",
          "settings": {
            "image": "shopify://shop_images/Wave_GJmr-9073.jpg",
            "subheading": "2018",
            "heading": "Wave is founded.",
            "heading_tag": "h2",
            "text": "<p>Two founders, one conviction: that the things putting people off owning a hot tub - patios, contractors, five-figure budgets - were the wrong problem to be solving.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
