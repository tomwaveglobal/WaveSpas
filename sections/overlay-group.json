 }\n\n    function isOpen() {\n      return modal.hasAttribute('open') || modal.hasAttribute('active') ||\n             modal.classList.contains('open') || modal.classList.contains('active');\n    }\n\n    function update() {\n      if (isOpen() && position()) {\n        img.classList.add('is-visible');\n      } else {\n        img.classList.remove('is-visible');\n      }\n    }\n\n    update();\n    new MutationObserver(update).observe(modal, {\n      attributes: true, attributeFilter: ['open', 'active', 'class']\n    });\n    window.addEventListener('resize', function() { if (isOpen()) position(); });\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n  setTimeout(init, 500);\n  setTimeout(init, 1500);\n})();\n</script>"
