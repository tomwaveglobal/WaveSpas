{%- comment -%}
  Mega Bundle
  ───────────────────────────────────────────────────────────────
  Repeatable "bundle" blocks. Each block is one curated bundle and
  reuses the theme's compact-product-bundle design 1:1 (promo image
  panel + product card-grid + single add-to-cart button), with the
  new functionality layered on top:
   • Variant-level: per item = product + optional Variant ID
     (blank → first available) + quantity. Merchant-locked variant.
   • Savings DISPLAY-ONLY (regular total, bundle price, £/% saved)
     from a per-bundle discount %. Pair with a Shopify automatic
     discount so it applies at checkout.
   • Single click adds every item in one /cart/add.js call
     (assets/mega-bundle.js).
   • Theme-editor-only panel below each bundle lists every item's
     variants, IDs and stock for easy copy/paste.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  #shopify-section-{{ section.id }} .mega-bundle + .mega-bundle { margin-top: var(--sp-16, 4rem); }
  #shopify-section-{{ section.id }} .mega-bundle__summary {
    margin-top: var(--sp-2, 0.5rem);
    padding-top: var(--sp-5, 1.25rem);
    border-top: 1px solid rgb(var(--color-foreground) / 0.12);
  }
  #shopify-section-{{ section.id }} .mega-bundle__saving {
    background: var(--gradient-highlight, var(--color-highlight, #e0a580));
    color: #171717;
  }
  #shopify-section-{{ section.id }} .product-card--promo .product-card__media::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, rgba(0,0,0,0.62), rgba(0,0,0,0) 55%);
    pointer-events: none;
  }
  /* Editor-only variant ID + stock panel */
  #shopify-section-{{ section.id }} .mega-bundle__editor { margin-top: var(--sp-5, 1.25rem); border: 1px dashed rgb(var(--color-foreground) / 0.3); border-radius: 8px; padding: var(--sp-4, 1rem); font-size: 0.72rem; background: rgb(var(--color-foreground) / 0.03); }
  #shopify-section-{{ section.id }} .mega-bundle__editor h4 { font-weight: 700; margin-bottom: 0.5rem; }
  #shopify-section-{{ section.id }} .mega-bundle__editor details + details { margin-top: 0.4rem; }
  #shopify-section-{{ section.id }} .mega-bundle__editor summary { cursor: pointer; }
  #shopify-section-{{ section.id }} .mega-bundle__editor code { user-select: all; font-weight: 600; }
  #shopify-section-{{ section.id }} .mega-bundle__editor .scroll { overflow-x: auto; }
  #shopify-section-{{ section.id }} .mega-bundle__id-table { width: 100%; border-collapse: collapse; margin-top: 0.4rem; }
  #shopify-section-{{ section.id }} .mega-bundle__id-table th,
  #shopify-section-{{ section.id }} .mega-bundle__id-table td { text-align: left; padding: 0.2rem 0.6rem; border-bottom: 1px solid rgb(var(--color-foreground) / 0.1); white-space: nowrap; }
  #shopify-section-{{ section.id }} .mega-bundle__id-table tr.is-active { background: rgb(var(--color-highlight, 224 165 128) / 0.18); }
  #shopify-section-{{ section.id }} .mega-bundle__id-table .oos { color: #b3261e; }
  #shopify-section-{{ section.id }} .mega-bundle__editor .oos { color: #b3261e; font-weight: 600; }
</style>

{{ 'product-bundle.css' | asset_url | stylesheet_tag }}
<script src="{{ 'mega-bundle.js' | asset_url }}" defer="defer"></script>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank -%}
      <div class="title-wrapper leading-none grid gap-3 {{ section.settings.heading_alignment }} relative z-1 mb-10">
        {%- if section.settings.subheading != blank -%}
          <p class="heading normal-case subtitle-sm leading-none tracking-none">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          {%- liquid
            assign with_gradient = false
            if section.settings.gradient_highlight != blank and section.settings.gradient_highlight != 'rgba(0,0,0,0)'
              assign with_gradient = true
            endif
          -%}
          <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }} leading-none tracking-tight">
            {%- render 'heading-content', content: section.settings.heading, style: section.settings.highlighted_text, scribble: section.settings.highlighted_scribble, reveal: section.settings.highlighted_reveal, gradient: with_gradient -%}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="rte leading-normal">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- liquid
        # ── Resolve every item once: totals, availability, column count ──
        assign regular_total = 0
        assign item_count = 0
        assign any_unavailable = false
        for n in (1..6)
          assign prod = block.settings['product_' | append: n]
          if prod == blank
            continue
          endif
          assign qty = block.settings['qty_' | append: n] | default: 1
          assign vid_str = block.settings['variant_' | append: n] | strip
          assign chosen = blank
          if vid_str != blank
            assign vid_num = vid_str | plus: 0
            for v in prod.variants
              if v.id == vid_num
                assign chosen = v
                break
              endif
            endfor
          endif
          if chosen == blank
            assign chosen = prod.selected_or_first_available_variant
          endif
          assign line_subtotal = chosen.price | times: qty
          assign regular_total = regular_total | plus: line_subtotal
          assign item_count = item_count | plus: 1
          unless chosen.available
            assign any_unavailable = true
          endunless
        endfor

        assign cols = item_count | at_most: 4 | at_least: 1
        assign pct = block.settings.discount_percent | default: 0
        assign saving = regular_total | times: pct | divided_by: 100
        assign bundle_total = regular_total | minus: saving
        assign has_image = block.settings.image
      -%}
      <mega-bundle class="mega-bundle block relative" id="MegaBundle-{{ section.id }}-{{ block.id }}" {{ block.shopify_attributes }}>
        <div class="compact-product-bundle-wrapper flex flex-col gap-6{% if has_image != blank %} lg:grid lg:gap-10{% unless block.settings.image_position == 'left' %} lg:grid-row-reverse{% endunless %}{% endif %}">
          {%- if has_image != blank -%}
            {%- comment -%} Promo image card — same structure/classes as compact-product-bundle {%- endcomment -%}
            <div class="card product-card product-card--promo block leading-none relative overflow-hidden">
              <div class="product-card__media relative top-0 left-0 w-full h-full">
                <div class="media media--height block w-full h-full relative overflow-hidden">
                  {{ has_image | image_url: width: has_image.width | image_tag: loading: 'lazy', widths: '300,500,700,900,1200,1600', sizes: '(max-width: 1023px) 100vw, 45vw', is: 'lazy-image' }}
                </div>
              </div>
              {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
                <div class="product-card__content z-1 absolute top-0 left-0 w-full h-full flex justify-center items-end" style="color:#fff;">
                  <div class="w-full text-left">
                    {%- if block.settings.heading != blank -%}
                      <h3 class="heading leading-none tracking-tight text-2xl lg:text-3xl">{{ block.settings.heading | escape }}</h3>
                    {%- endif -%}
                    {%- if block.settings.subheading != blank -%}
                      <div class="rte leading-normal mt-2" style="color:rgba(255,255,255,0.9);">{{ block.settings.subheading }}</div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- elsif block.settings.heading != blank or block.settings.subheading != blank -%}
            <div class="title-wrapper leading-none grid gap-2">
              {%- if block.settings.heading != blank -%}
                <h3 class="heading text-2xl lg:text-3xl leading-none tracking-tight">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.subheading != blank -%}
                <div class="rte text-opacity leading-normal">{{ block.settings.subheading }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}

          <div class="compact-product-bundle flex flex-col gap-6 lg:gap-8">
            <motion-list class="product-grid card-grid card-grid--{{ cols }} mobile:card-grid--1 grid">
              {%- assign rendered = 0 -%}
              {%- for n in (1..6) -%}
                {%- assign prod = block.settings['product_' | append: n] -%}
                {%- if prod != blank -%}
                  {%- liquid
                    assign qty = block.settings['qty_' | append: n] | default: 1
                    assign vid_str = block.settings['variant_' | append: n] | strip
                    assign chosen = blank
                    if vid_str != blank
                      assign vid_num = vid_str | plus: 0
                      for v in prod.variants
                        if v.id == vid_num
                          assign chosen = v
                          break
                        endif
                      endfor
                    endif
                    if chosen == blank
                      assign chosen = prod.selected_or_first_available_variant
                    endif
                  -%}
                  <div class="grid relative" data-mega-bundle-item data-variant-id="{{ chosen.id }}" data-qty="{{ qty }}">
                    {%- if rendered > 0 -%}
                      {%- render 'icon', icon: 'plus-3', size: 'xl', class: 'icon-bundle-plus absolute pointer-events-none' -%}
                    {%- endif -%}
                    {%- render 'mega-bundle-card',
                      product: prod,
                      variant: chosen,
                      qty: qty,
                      image_ratio: settings.product_image_ratio,
                      image_fill: settings.product_image_fill,
                      show_vendor: settings.product_vendor,
                      show_sold_out: true,
                      show_save_amount: settings.product_save_amount,
                      save_type: settings.product_save_type
                    -%}
                  </div>
                  {%- assign rendered = rendered | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            </motion-list>

            <div class="mega-bundle__summary flex flex-col gap-4">
              <div class="flex items-end justify-between gap-4 flex-wrap">
                <div class="flex items-baseline gap-3 flex-wrap">
                  <span class="heading text-base font-medium shrink-0">{{ 'sections.product_bundle.total' | t | default: 'Total' }}</span>
                  {%- if pct > 0 and saving > 0 and section.settings.show_regular_total -%}
                    <s class="text-opacity text-base">{{ regular_total | money }}</s>
                  {%- endif -%}
                  <span class="heading text-xl lg:text-2xl font-bold leading-none">{{ bundle_total | money }}</span>
                </div>
                {%- if pct > 0 and saving > 0 -%}
                  <span class="mega-bundle__saving badge inline-flex items-center rounded-full px-3 py-1d5 text-sm font-semibold">
                    {%- if block.settings.savings_label != blank -%}
                      {{ block.settings.savings_label | escape }}
                    {%- else -%}
                      Save {{ saving | money }} ({{ pct }}%)
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </div>

              <button type="button" class="button button--primary w-full" is="hover-button" data-mega-bundle-add aria-label="{{ block.settings.button_label | default: 'Add bundle to cart' | escape }}"{% if item_count < 1 or any_unavailable %} disabled{% endif %}>
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- if any_unavailable -%}
                    {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                  {%- else -%}
                    {{ block.settings.button_label | default: 'Add bundle to cart' }}
                  {%- endif -%}
                </span>
              </button>
              <p class="text-xs text-opacity text-center">{{ 'sections.product_bundle.discounts_at_checkout' | t | default: 'Discounts applied at checkout' }}</p>
              <div class="product-form__error-message alert alert--error text-sm font-medium leading-tight text-center" role="alert" hidden></div>
            </div>
          </div>
        </div>

        {%- if request.design_mode -%}
          <div class="mega-bundle__editor">
            <h4>Theme editor · variant IDs &amp; stock</h4>
            {%- for n in (1..6) -%}
              {%- assign prod = block.settings['product_' | append: n] -%}
              {%- if prod != blank -%}
                {%- liquid
                  assign vid_str = block.settings['variant_' | append: n] | strip
                  assign chosen = blank
                  if vid_str != blank
                    assign vid_num = vid_str | plus: 0
                    for v in prod.variants
                      if v.id == vid_num
                        assign chosen = v
                        break
                      endif
                    endfor
                  endif
                  if chosen == blank
                    assign chosen = prod.selected_or_first_available_variant
                  endif
                -%}
                <details>
                  <summary>
                    <strong>Item {{ n }}:</strong> {{ prod.title }} &mdash;
                    selected <code>{{ chosen.id }}</code>{% if chosen.sku != blank %} (SKU {{ chosen.sku }}){% endif %}
                    &middot;
                    {%- if chosen.available -%}
                      {% if chosen.inventory_management != blank %}{{ chosen.inventory_quantity }} in stock{% else %}available{% endif %}
                    {%- else -%}
                      <span class="oos">unavailable</span>
                    {%- endif -%}
                  </summary>
                  <div class="scroll">
                    <table class="mega-bundle__id-table">
                      <tr><th>Variant</th><th>SKU</th><th>ID</th><th>Stock</th></tr>
                      {%- for v in prod.variants -%}
                        <tr class="{% if v.id == chosen.id %}is-active{% endif %}">
                          <td>{{ v.title }}</td>
                          <td>{{ v.sku | default: '&mdash;' }}</td>
                          <td><code>{{ v.id }}</code></td>
                          <td class="{% unless v.available %}oos{% endunless %}">
                            {%- if v.inventory_management != blank -%}
                              {{ v.inventory_quantity }}
                            {%- elsif v.available -%}
                              avail.
                            {%- else -%}
                              n/a
                            {%- endif -%}
                          </td>
                        </tr>
                      {%- endfor -%}
                    </table>
                  </div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </mega-bundle>
    {%- else -%}
      {%- if request.design_mode -%}
        <p class="text-center text-opacity">Add a bundle block to get started.</p>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Mega Bundle",
  "tag": "section",
  "class": "section-mega-bundle compact-product-bundle-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Mega Bundles"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "lg:text-2xl text-2xl", "label": "Small" },
        { "value": "lg:text-3xl text-2xl", "label": "Medium" },
        { "value": "lg:text-4xl text-2xl", "label": "Large" },
        { "value": "lg:text-5xl text-2xl", "label": "Extra large" }
      ],
      "default": "lg:text-4xl text-2xl",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2",
      "label": "Heading tag"
    },
    {
      "type": "select",
      "id": "highlighted_text",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "scribble", "label": "Scribble" },
        { "value": "underline", "label": "Underline" },
        { "value": "marker", "label": "Marker" }
      ],
      "default": "none",
      "label": "Highlight style"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text == 'scribble' }}",
      "type": "select",
      "id": "highlighted_scribble",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "basic-underline", "label": "Basic underline" },
        { "value": "sketch-underline", "label": "Sketch underline" },
        { "value": "squiggle-underline", "label": "Squiggle underline" }
      ],
      "default": "circle",
      "label": "Scribble style"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text != 'none' }}",
      "type": "checkbox",
      "id": "highlighted_reveal",
      "label": "Reveal on scroll",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_regular_total",
      "default": true,
      "label": "Show regular (struck-through) total"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Leave blank to inherit theme defaults."
    },
    { "type": "color", "id": "color_text", "label": "Text" },
    { "type": "color", "id": "color_background", "label": "Background" },
    { "type": "color_background", "id": "gradient_background", "label": "Background gradient" },
    { "type": "color", "id": "color_highlight", "label": "Saving badge" },
    { "type": "color_background", "id": "gradient_highlight", "label": "Highlight gradient" },
    { "type": "color", "id": "color_button_text", "label": "Button text" },
    { "type": "color", "id": "color_button_background", "label": "Button background" },
    { "type": "color_background", "id": "color_button_gradient", "label": "Button gradient" },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show divider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": true,
      "label": "Rounded corners"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Bundle name",
          "default": "Hot Tub Bundle"
        },
        {
          "type": "richtext",
          "id": "subheading",
          "label": "Bundle description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bundle image (optional)",
          "info": "Shown as a promo panel beside the products, with the bundle name/description overlaid."
        },
        {
          "type": "select",
          "id": "image_position",
          "options": [
            { "value": "right", "label": "Right" },
            { "value": "left", "label": "Left" }
          ],
          "default": "right",
          "label": "Image position (desktop)"
        },
        {
          "type": "range",
          "id": "discount_percent",
          "min": 0,
          "max": 70,
          "step": 1,
          "unit": "%",
          "label": "Discount %",
          "default": 10,
          "info": "Display only. Set a matching Shopify automatic discount so the saving applies at checkout."
        },
        {
          "type": "text",
          "id": "savings_label",
          "label": "Saving label override",
          "info": "Optional. Leave blank to auto-show 'Save £X (Y%)'."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Add bundle to cart"
        },
        {
          "type": "header",
          "content": "Item 1",
          "info": "Leave Variant ID blank to use the first available variant. The panel below each bundle (theme editor only) lists each product's variant IDs + stock to copy."
        },
        { "type": "product", "id": "product_1", "label": "Product 1" },
        { "type": "text", "id": "variant_1", "label": "Variant ID 1 (optional)" },
        { "type": "range", "id": "qty_1", "min": 1, "max": 10, "step": 1, "default": 1, "label": "Quantity 1" },
        { "type": "header", "content": "Item 2" },
        { "type": "product", "id": "product_2", "label": "Product 2" },
        { "type": "text", "id": "variant_2", "label": "Variant ID 2 (optional)" },
        { "type": "range", "id": "qty_2", "min": 1, "max": 10, "step": 1, "default": 1, "label": "Quantity 2" },
        { "type": "header", "content": "Item 3" },
        { "type": "product", "id": "product_3", "label": "Product 3" },
        { "type": "text", "id": "variant_3", "label": "Variant ID 3 (optional)" },
        { "type": "range", "id": "qty_3", "min": 1, "max": 10, "step": 1, "default": 1, "label": "Quantity 3" },
        { "type": "header", "content": "Item 4" },
        { "type": "product", "id": "product_4", "label": "Product 4" },
        { "type": "text", "id": "variant_4", "label": "Variant ID 4 (optional)" },
        { "type": "range", "id": "qty_4", "min": 1, "max": 10, "step": 1, "default": 1, "label": "Quantity 4" },
        { "type": "header", "content": "Item 5" },
        { "type": "product", "id": "product_5", "label": "Product 5" },
        { "type": "text", "id": "variant_5", "label": "Variant ID 5 (optional)" },
        { "type": "range", "id": "qty_5", "min": 1, "max": 10, "step": 1, "default": 1, "label": "Quantity 5" },
        { "type": "header", "content": "Item 6" },
        { "type": "product", "id": "product_6", "label": "Product 6" },
        { "type": "text", "id": "variant_6", "label": "Variant ID 6 (optional)" },
        { "type": "range", "id": "qty_6", "min": 1, "max": 10, "step": 1, "default": 1, "label": "Quantity 6" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Mega Bundle",
      "category": "Products",
      "blocks": [
        { "type": "bundle" },
        { "type": "bundle" },
        { "type": "bundle" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"],
    "templates": ["password"]
  }
}
{% endschema %}
