{%- comment -%}
  Mega Bundle
  ───────────────────────────────────────────────────────────────
  Built on the theme's compact-product-bundle look (promo image panel +
  product card-grid + product-bundle.css) with new functionality:
   • Each item is a "product" block: a product + the variant IDs you allow
     (blank = all) + quantity. The customer picks from ONLY the allowed
     variants via pill buttons. The merchant copies IDs from the editor
     panel below (lists each product's variants, IDs and stock).
   • Live total + £/% savings from a per-bundle Discount % (display only —
     pair with a Shopify automatic discount so it applies at checkout).
   • Single click adds every selected variant in one /cart/add.js call.
  JS: assets/mega-bundle.js.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  {%- assign image_mobile = section.settings.image_mobile | default: section.settings.image -%}
  {%- if image_mobile != blank and section.settings.image_height_mobile == 'adapt' %}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} { --ratio-percent: {{ 1 | divided_by: image_mobile.aspect_ratio | times: 100 }}%; }
    }
  {% endif -%}

  #shopify-section-{{ section.id }} .mega-variant-btn { border: 1px solid rgb(var(--color-foreground) / 0.3); border-radius: 999px; padding: 0.35rem 0.8rem; font-size: 0.8rem; line-height: 1; cursor: pointer; background: transparent; color: inherit; transition: background 0.15s, color 0.15s, border-color 0.15s; }
  #shopify-section-{{ section.id }} .mega-variant-btn:hover { border-color: rgb(var(--color-foreground) / 0.6); }
  #shopify-section-{{ section.id }} .mega-variant-btn.is-active { border-color: rgb(var(--color-foreground)); background: rgb(var(--color-foreground)); color: rgb(var(--color-background, 255 255 255)); }
  #shopify-section-{{ section.id }} .mega-variant-btn.is-unavailable { opacity: 0.4; text-decoration: line-through; }
  #shopify-section-{{ section.id }} .mega-bundle__saving { background: var(--gradient-highlight, var(--color-highlight, #e0a580)); color: #171717; }

  #shopify-section-{{ section.id }} .mega-bundle__editor { margin-top: var(--sp-6, 1.5rem); border: 1px dashed rgb(var(--color-foreground) / 0.3); border-radius: 8px; padding: var(--sp-4, 1rem); font-size: 0.72rem; background: rgb(var(--color-foreground) / 0.03); }
  #shopify-section-{{ section.id }} .mega-bundle__editor h4 { font-weight: 700; margin-bottom: 0.5rem; }
  #shopify-section-{{ section.id }} .mega-bundle__editor-hint { margin-bottom: 0.6rem; opacity: 0.85; }
  #shopify-section-{{ section.id }} .mega-bundle__editor-product { padding: 0.6rem 0; border-top: 1px solid rgb(var(--color-foreground) / 0.12); }
  #shopify-section-{{ section.id }} .mega-bundle__editor-product:first-of-type { border-top: 0; }
  #shopify-section-{{ section.id }} .mega-bundle__options { display: grid; gap: 0.15rem; margin: 0.3rem 0; }
  #shopify-section-{{ section.id }} .mega-bundle__options .opt-name { font-weight: 600; margin-right: 0.25rem; }
  #shopify-section-{{ section.id }} .mega-bundle__editor summary { cursor: pointer; }
  #shopify-section-{{ section.id }} .mega-bundle__editor code { user-select: all; font-weight: 600; }
  #shopify-section-{{ section.id }} .mega-bundle__editor .scroll { overflow-x: auto; }
  #shopify-section-{{ section.id }} .mega-bundle__id-table { width: 100%; border-collapse: collapse; margin-top: 0.4rem; }
  #shopify-section-{{ section.id }} .mega-bundle__id-table th,
  #shopify-section-{{ section.id }} .mega-bundle__id-table td { text-align: left; padding: 0.2rem 0.6rem; border-bottom: 1px solid rgb(var(--color-foreground) / 0.1); white-space: nowrap; }
  #shopify-section-{{ section.id }} .mega-bundle__id-table .oos { color: #b3261e; }
</style>

{{ 'product-bundle.css' | asset_url | stylesheet_tag }}
<script src="{{ 'mega-bundle.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign product_blocks = section.blocks | where: 'type', 'product'
  assign cols = product_blocks.size | at_most: 4 | at_least: 1
  assign pct = section.settings.discount_percent | default: 0
-%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    <mega-bundle data-discount="{{ pct }}" class="compact-product-bundle-wrapper flex flex-col gap-6 lg:grid lg:gap-10{% unless section.settings.layout == 'image_first' %} lg:grid-row-reverse{% endunless %}">

      {%- comment -%} Promo image panel — same structure/classes as compact-product-bundle {%- endcomment -%}
      <div class="card product-card product-card--promo block leading-none relative overflow-hidden" id="shopify-block-{{ section.id }}">
        {%- assign color_overlay_brightness = section.settings.color_overlay | color_brightness -%}
        <style>
          #shopify-block-{{ section.id }} {
            {%- if color_overlay_brightness < 150 %}
              --color-foreground: 255 255 255;
              --color-button-gradient: #ffffff;
              --color-button-background: 255 255 255;
              --color-button-border: 255 255 255;
              --color-button-text: 0 0 0;
            {% else %}
              --color-foreground: 0 0 0;
              --color-button-gradient: #000000;
              --color-button-background: 0 0 0;
              --color-button-border: 0 0 0;
              --color-button-text: 255 255 255;
            {% endif -%}
          }
        </style>
        <div class="product-card__media mobile:media--{{ section.settings.image_height_mobile }} relative top-0 left-0 w-full h-full">
          <media-element class="media flex top-0 left-0 w-full h-full relative overflow-hidden"{% if section.settings.enable_parallax %} data-parallax="0.3" data-parallax-dir="{{ section.settings.parallax_direction }}"{% endif %}>
            <picture class="media media--height block w-full h-full relative overflow-hidden">
              {%- if section.settings.image != blank -%}
                {%- if section.settings.image_mobile -%}
                  <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: '400x' }} 400w, {{ section.settings.image_mobile | image_url: width: '800x' }} 800w" width="{{ section.settings.image_mobile.width }}" height="{{ section.settings.image_mobile.height }}">
                {%- endif -%}
                {{- section.settings.image | image_url: width: section.settings.image.width | image_tag: loading: 'lazy', widths: '300,400,500,600,700,800,900,1000,1200,1400,1600', sizes: '(max-width: 1023px) 100vw, 55vw', is: 'lazy-image' -}}
              {%- else -%}
                {{- 'collection-1' | placeholder_svg_tag: 'placeholder' -}}
              {%- endif -%}
            </picture>
          </media-element>
        </div>
        {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank -%}
          <div class="product-card__content z-1 absolute top-0 left-0 w-full h-full flex justify-center {{ section.settings.content_position_mobile }} {{ section.settings.content_position }}">
            <div class="md:text-{{ section.settings.text_alignment }} text-{{ section.settings.text_alignment_mobile }} w-full">
              <div class="promo-box inline-block">
                {%- if section.settings.subheading != blank -%}
                  <p class="banner__subheading heading uppercase leading-none tracking-widest subtitle-md">{{ section.settings.subheading | escape }}</p>
                {%- endif -%}
                {%- if section.settings.heading != blank -%}
                  <h2 class="banner__title heading leading-none title-md">{{ section.settings.heading }}</h2>
                {%- endif -%}
                {%- if section.settings.description != blank -%}
                  <div class="rte leading-normal mt-2">{{ section.settings.description }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Bundle column: product grid + total + add button {%- endcomment -%}
      <div class="compact-product-bundle flex flex-col gap-6 lg:gap-10">
        <div class="product-grid card-grid card-grid--{{ cols }} mobile:card-grid--1 grid">
          {%- assign reg_total = 0 -%}
          {%- assign rendered = 0 -%}
          {%- for block in product_blocks -%}
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              {%- liquid
                assign allowed = block.settings.allowed_variants
                assign exclude_words = block.settings.exclude_words
                assign has_filter = false
                if allowed != blank
                  assign has_filter = true
                  assign allowed_norm = allowed | remove: ' ' | prepend: ',' | append: ','
                endif
                assign has_exclude = false
                if exclude_words != blank
                  assign has_exclude = true
                  assign exclude_list = exclude_words | split: ','
                endif
                assign selected = blank
                assign first_offered = blank
                for v in product.variants
                  assign offer = true
                  if has_filter
                    assign needle = ',' | append: v.id | append: ','
                    unless allowed_norm contains needle
                      assign offer = false
                    endunless
                  endif
                  if offer and has_exclude
                    assign vtitle = v.title | downcase
                    for w in exclude_list
                      assign wt = w | strip | downcase
                      if wt != blank and vtitle contains wt
                        assign offer = false
                        break
                      endif
                    endfor
                  endif
                  if offer
                    if first_offered == blank
                      assign first_offered = v
                    endif
                    if selected == blank and v.available
                      assign selected = v
                    endif
                  endif
                endfor
                if selected == blank
                  assign selected = first_offered
                endif
                if selected == blank
                  assign selected = product.selected_or_first_available_variant
                endif
                assign qty = block.settings.quantity | default: 1
                assign line_subtotal = selected.price | times: qty
                assign reg_total = reg_total | plus: line_subtotal
              -%}
              <div class="grid relative" {{ block.shopify_attributes }}>
                {%- if rendered > 0 -%}
                  {%- render 'icon', icon: 'plus-3', size: 'xl', class: 'icon-bundle-plus absolute pointer-events-none' -%}
                {%- endif -%}
                {%- render 'mega-bundle-card', product: product, variant: selected, allowed_variants: allowed, exclude_words: exclude_words, qty: qty -%}
              </div>
              {%- assign rendered = rendered | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- liquid
          assign saving = reg_total | times: pct | divided_by: 100
          assign bundle_total = reg_total | minus: saving
        -%}
        <div class="flex flex-col gap-4">
          <div class="flex items-end justify-between gap-3 flex-wrap">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="heading text-base font-medium">{{ section.settings.savings_label | default: 'Bundle total' }}</span>
              <s class="text-opacity" data-mega-regular{% unless pct > 0 %} hidden{% endunless %}>{{ reg_total | money }}</s>
              <span class="heading text-xl font-bold leading-none" data-mega-total>{{ bundle_total | money }}</span>
            </div>
            <span class="mega-bundle__saving badge inline-flex items-center rounded-full px-3 py-1d5 text-sm font-semibold" data-mega-saving{% unless pct > 0 %} hidden{% endunless %}>Save <span data-mega-saving-amt>{{ saving | money }}</span> ({{ pct }}%)</span>
          </div>

          <button type="button" class="button button--primary w-full" is="hover-button" data-mega-add aria-label="{{ 'sections.product_bundle.add_to_cart' | t | default: 'Add bundle to cart' | escape }}">
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">{{ 'sections.product_bundle.add_to_cart' | t | default: 'Add bundle to cart' }}</span>
          </button>
          <p class="text-xs text-opacity text-center">{{ 'sections.product_bundle.discounts_at_checkout' | t | default: 'Discounts applied at checkout' }}</p>
          <div class="product-form__error-message alert alert--error text-sm font-medium leading-tight text-center" role="alert" data-mega-error hidden></div>
        </div>
      </div>
    </mega-bundle>

    {%- if request.design_mode -%}
      <div class="mega-bundle__editor">
        <h4>Theme editor · choose which variants customers can pick</h4>
        <p class="mega-bundle__editor-hint">Copy the IDs you want into each item's <strong>Allowed variant IDs</strong>, and/or type option words into <strong>Exclude variants containing</strong> (e.g. <code>EnergySave</code> to drop the EnergySave edition).</p>
        {%- for block in product_blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <div class="mega-bundle__editor-product">
              <p class="mega-bundle__editor-title">
                <strong>{{ product.title }}</strong> &mdash; {{ product.variants.size }} variant(s)
                {%- if block.settings.allowed_variants != blank %} · allowing IDs: {{ block.settings.allowed_variants }}{% else %} · allowing: all{% endif -%}
                {%- if block.settings.exclude_words != blank %} · excluding: &ldquo;{{ block.settings.exclude_words }}&rdquo;{% endif -%}
              </p>
              <div class="mega-bundle__options">
                {%- for opt in product.options_with_values -%}
                  <div class="opt"><span class="opt-name">{{ opt.name }}:</span>
                    {%- for value in opt.values -%}{% unless forloop.first %}, {% endunless %}{{ value.name | default: value }}{%- endfor -%}
                  </div>
                {%- endfor -%}
                <div class="opt"><span class="opt-name">All IDs:</span> <code>{% for v in product.variants %}{{ v.id }}{% unless forloop.last %},{% endunless %}{% endfor %}</code></div>
              </div>
              <details open>
                <summary>Variant IDs &amp; stock (copy an ID into Allowed variant IDs)</summary>
                <div class="scroll">
                  <table class="mega-bundle__id-table">
                    <tr><th>Variant</th><th>SKU</th><th>ID</th><th>Stock</th></tr>
                    {%- for v in product.variants -%}
                      <tr>
                        <td>{{ v.title }}</td>
                        <td>{{ v.sku | default: '&mdash;' }}</td>
                        <td><code>{{ v.id }}</code></td>
                        <td class="{% unless v.available %}oos{% endunless %}">
                          {%- if v.inventory_management != blank -%}{{ v.inventory_quantity }}{%- elsif v.available -%}avail.{%- else -%}n/a{%- endif -%}
                        </td>
                      </tr>
                    {%- endfor -%}
                  </table>
                </div>
              </details>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Mega Bundle",
  "class": "compact-product-bundle-section section-mega-bundle",
  "settings": [
    {
      "type": "header",
      "content": "Promo panel"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Hot Tub Bundle"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Buy together and save.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        { "value": "image_first", "label": "Image left" },
        { "value": "text_first", "label": "Image right" }
      ],
      "default": "image_first",
      "label": "Image position (desktop)"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        { "value": "md:items-start", "label": "Top" },
        { "value": "md:items-center", "label": "Middle" },
        { "value": "md:items-end", "label": "Bottom" }
      ],
      "default": "md:items-end",
      "label": "Text position"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "default": "left",
      "label": "Text alignment"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "select",
      "id": "image_height_mobile",
      "options": [
        { "value": "200px", "label": "200px" },
        { "value": "300px", "label": "300px" },
        { "value": "400px", "label": "400px" },
        { "value": "500px", "label": "500px" },
        { "value": "adapt", "label": "Adapt to image" }
      ],
      "default": "300px",
      "label": "Mobile image height"
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "options": [
        { "value": "items-start", "label": "Top" },
        { "value": "items-center", "label": "Middle" },
        { "value": "items-end", "label": "Bottom" }
      ],
      "default": "items-end",
      "label": "Text position (mobile)"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment_mobile",
      "default": "left",
      "label": "Text alignment (mobile)"
    },
    {
      "type": "header",
      "content": "Bundle saving"
    },
    {
      "type": "range",
      "id": "discount_percent",
      "min": 0,
      "max": 70,
      "step": 1,
      "unit": "%",
      "label": "Discount %",
      "default": 10,
      "info": "Display only — drives the total + 'Save £X (Y%)'. Set a matching Shopify automatic discount so it applies at checkout."
    },
    {
      "type": "text",
      "id": "savings_label",
      "label": "Total label",
      "default": "Bundle total"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Leave blank to inherit theme defaults."
    },
    { "type": "color", "id": "color_text", "label": "Text" },
    { "type": "color", "id": "color_background", "label": "Background" },
    { "type": "color_background", "id": "gradient_background", "label": "Background gradient" },
    { "type": "color", "id": "color_highlight", "label": "Saving badge" },
    { "type": "color_background", "id": "gradient_highlight", "label": "Highlight gradient" },
    { "type": "color", "id": "color_button_text", "label": "Button text" },
    { "type": "color", "id": "color_button_background", "label": "Button background" },
    { "type": "color_background", "id": "color_button_gradient", "label": "Button gradient" },
    {
      "type": "color",
      "id": "color_overlay",
      "label": "Image overlay",
      "default": "#171717"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show divider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": true,
      "label": "Rounded corners"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable parallax",
      "default": false
    },
    {
      "type": "select",
      "id": "parallax_direction",
      "label": "Parallax direction",
      "default": "vertical",
      "visible_if": "{{ section.settings.enable_parallax == true }}",
      "options": [
        { "value": "vertical", "label": "Vertical" },
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "zoom", "label": "Zoom" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "allowed_variants",
          "label": "Allowed variant IDs",
          "info": "Comma-separated variant IDs the customer may pick from. Leave blank to allow all. Copy IDs from the panel shown below the bundle in the preview."
        },
        {
          "type": "text",
          "id": "exclude_words",
          "label": "Exclude variants containing",
          "info": "Comma-separated words. Any variant whose name contains one of these is hidden (e.g. Energy Save). Applied on top of the allowed list."
        },
        {
          "type": "range",
          "id": "quantity",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1,
          "label": "Quantity"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Mega Bundle",
      "category": "Products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"],
    "templates": ["password"]
  }
}
{% endschema %}
